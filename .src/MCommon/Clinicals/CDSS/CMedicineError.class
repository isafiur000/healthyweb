''---------------------- other target drug-----------------------------------
Public Sub DrugDrugInteractions(targDrug As String)

  Dim xColl As Collection
  Dim xWarn As String
  Dim codeid As String

  'Drug-drug interaction
  ' If $DrugInteraction = "Yes" Then
  codeid = modMedConstant.GetCodeFromDrugID(targDrug)
  xWarn = GetMedicineReviewWarningMultiple($stockid, "MedicationReview/DrugInteraction", codeid)
  If xWarn Then

    xColl = New Collection
    xColl.Add("Drug Interaction", "Category")
    xColl.Add(modMedConstant.GetCodeFromStockID($stockid), "Drug")
    xColl.Add(codeid, "Condition")
    xColl.Add(xWarn, "Warning")
    $xVar.Add(xColl)

  Endif
  ' Endif

End

