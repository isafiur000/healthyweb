Public Sub LaboratoryInteractions(hypoTestList As String[], hyperTestList As String[])

  Dim xColl As Collection
  Dim xx As String
  Dim yy As String
  Dim res As Result
  Dim res1 As Result

  ' xhypo = modLabTest.GetHypoTestList(encid)
  ' xhyper = modLabTest.GetHyperTestList(encid)
  ' If $LaboratoryInteraction = "Yes" Then
  If hypoTestList And If hypoTestList.Count Then
    For Each xx In hypoTestList
      res = modDatabase.$medConn.Exec("select fldparent,fldchild,fldreference from tblcodehypo where fldparent=&1 and fldchild=&2", xx, $codeid)
      If res.Available Then
        res.MoveFirst

        xColl = New Collection
        xColl.Add("Lab Interaction", "Category")
        xColl.Add(res["fldchild"], "Drug")
        xColl.Add(res["fldparent"], "Condition")
        xColl.Add(res["fldparent"] & " values further DECREASED by " & res["fldchild"] & " [" & res["fldreference"] & "]", "Warning")
        $xVar.Add(xColl)

      Endif
    Next
  Endif

  If hyperTestList And If hyperTestList.Count Then
    For Each yy In hyperTestList
      res1 = modDatabase.$medConn.Exec("select fldparent,fldchild,fldreference from tblcodehyper where fldparent=&1 and fldchild=&2", yy, $codeid)
      If res1.Available Then
        res1.MoveFirst

        xColl = New Collection
        xColl.Add("Lab Interaction", "Category")
        xColl.Add(res1["fldchild"], "Drug")
        xColl.Add(res1["fldparent"], "Condition")
        xColl.Add(res1["fldparent"] & " values further INCREASED by " & res1["fldchild"] & " [" & res1["fldreference"] & "]", "Warning")
        $xVar.Add(xColl)

      Endif
    Next
  Endif
  ' Endif

End

Public Sub DrugResistance(sensiColl As Collection)

  Dim xColl As Collection
  Dim sensid As String

  'drug-drug resistance
  ' If $AntibioticResistance = "Yes" Then
  sensid = modMedConstant.GetSensiNameFromStockID($stockid)
  If sensid Then
    If sensiColl.Exist(sensid) Then

      xColl = New Collection
      xColl.Add("Drug Resistance", "Category")
      xColl.Add(sensid, "Drug")
      xColl.Add(sensiColl[sensid], "Condition")
      xColl.Add(sensid & " Found " & sensiColl[sensid] & " to isolated organism", "Warning")
      $xVar.Add(xColl)

    Endif
  Endif
  ' Endif

End

Public Sub PreAdminMonitoring(labList As String[])

  Dim xColl As Collection
  Dim prelablist As String[]
  Dim xx As String

  'pre admin monitoring
  ' donelablist = modLabTest.PaientAllTestNameArray(encid)
  ' If $PreAdminMonitor = "Yes" Then
  prelablist = modMedConstant.GetPreAdminTestList($codeid)
  If prelablist And If prelablist.Count Then
    For Each xx In prelablist
      If labList.Exist(xx) = False Then

        xColl = New Collection
        xColl.Add("Pre-Admin", "Category")
        xColl.Add($codeid, "Drug")
        xColl.Add(xx, "Condition")
        xColl.Add("Values of " & xx & " required before prescribing", "Warning")
        $xVar.Add(xColl)

      Endif
    Next
  Endif
  ' Endif

End

Public Sub ExamInteractions(bradyExamList As String[], tachyExamList As String[])

  Dim xColl As Collection
  Dim xx As String
  Dim yy As String
  Dim res As Result
  Dim res1 As Result

  ' xbrady = modClinic.GetBradyExamList(encid)
  ' xtachy = modClinic.GetTachyExamList(encid)
  ' If $ExaminationInteraction = "Yes" Then
  If bradyExamList And If bradyExamList.Count Then
    For Each xx In bradyExamList
      res = modDatabase.$medConn.Exec("select fldparent,fldchild,fldreference from tblcodebrady where fldparent=&1 and fldchild=&2", xx, $codeid)
      If res.Available Then
        res.MoveFirst

        xColl = New Collection
        xColl.Add("Examimations", "Category")
        xColl.Add(res["fldchild"], "Drug")
        xColl.Add(res["fldparent"], "Condition")
        xColl.Add(res["fldparent"] & " values further DECREASED by " & res["fldchild"] & " [" & res["fldreference"] & "]", "Warning")
        $xVar.Add(xColl)

      Endif
    Next
  Endif

  If tachyExamList And If tachyExamList.Count Then
    For Each yy In tachyExamList
      res1 = modDatabase.$medConn.Exec("select fldparent,fldchild,fldreference from tblcodetachy where fldparent=&1 and fldchild=&2", yy, $codeid)
      If res1.Available Then
        res1.MoveFirst

        xColl = New Collection
        xColl.Add("Examimations", "Category")
        xColl.Add(res1["fldchild"], "Drug")
        xColl.Add(res1["fldparent"], "Condition")
        xColl.Add(res1["fldparent"] & " values further INCREASED by " & res1["fldchild"] & " [" & res1["fldreference"] & "]", "Warning")
        $xVar.Add(xColl)

      Endif
    Next
  Endif
  ' Endif

End

''=========================== Procedures ================================================
Private Function GetMedicineReviewWarning(stockid As String, strCategory As String, Optional sValue As Variant) As String                                       ''

  Dim xx As String
  Dim ref As String
  Dim refdrug As String

  xx = ""
  '---------------------Code -------------------------------
  If strCategory = "MedicationReview/MaxUnitDose" Then ''complete
    ref = modMedConstant.GetInfoReferenceForCode(stockid)
    xx = "MAXIMUM Unit Dose is " & CStr(sValue) & " [" & ref & "]"

  Else If strCategory = "MedicationReview/MaxDailyDose" Then ''complete
    ref = modMedConstant.GetInfoReferenceForCode(stockid)
    xx = "MAXIMUM Daily Dose is " & CStr(sValue) & " [" & ref & "]"

  Else If strCategory = "MedicationReview/MinDailyDose" Then ''complete
    ref = modMedConstant.GetInfoReferenceForCode(stockid)
    xx = "MINIMUM Daily Dose is " & CStr(sValue) & " [" & ref & "]"

  Else If strCategory = "MedicationReview/MaxFrequency" Then ''complete
    ref = modMedConstant.GetInfoReferenceForCode(stockid)
    xx = "MAXIMUM Frequency is " & CStr(sValue) & " times [" & ref & "]"

  Else If strCategory = "MedicationReview/PRNRestriction" Then
    ref = modMedConstant.GetInfoReferenceForCode(stockid)
    xx = "Not prescribed on PRN basis [" & ref & "]"

    '-------------------------------------Drug --------------------------------------------
  Else If strCategory = "MedicationReview/AgeContraindication" Then
    refdrug = modMedConstant.GetInfoReferenceForDrug(stockid)
    xx = "CONTRAINDICATED below " & CStr(sValue) & " year [" & refdrug & "]"

    '------------------------------------ Brand --------------------------------------
  Else If strCategory = "MedicationReview/PreservativePrecaution" Then
    xx = "Contains PRESERVATIVE(" & sValue & "). May not be appropriate"

  Else If strCategory = "MedicationReview/DoseBreak" Then
    xx = "BREAKING of Dosage Form not appropriate"

  Endif

  Return xx

End

'-------------------------------------SET B warningd-------------------------------------------------------------------------------------------
Private Function GetMedicineReviewWarningMultiple(stockid As String, strCategory As String, strVal As String) As String

  Dim codeid As String
  Dim drugid As String
  Dim xx As String

  codeid = modMedConstant.GetCodeFromStockID(stockid)
  drugid = modMedConstant.GetDrugFromStockID(stockid)
  ''---------------------------------------------------single option -----------------------------------------------------------
  If strCategory = "MedicationReview/PregnancyPrecaution" Then
    xx = modTableCache.$CodePregnancyData[codeid & "|" & strVal]

  Else If strCategory = "MedicationReview/HepaticPrecaution" Then
    xx = modTableCache.$CodeHepaticData[codeid & "|" & strVal]

  Else If strCategory = "MedicationReview/RenalPrecaution" Then
    xx = modTableCache.$CodeRenalData[codeid & "|" & modMedicine.GetKidneyStatus(CFloat(strVal))]

  Else If strCategory = "MedicationReview/DrugInteraction" Then
    xx = modTableCache.$CodeDrugIntxnData[codeid & "|" & strVal]

  Else If strCategory = "MedicationReview/InjectionIncompatibility" Then
    xx = modTableCache.$DrugInjecIncompatData[drugid & "|" & strVal]

  Else If strCategory = "MedicationReview/IVFluidIncompatibility" Then
    xx = modTableCache.$DrugFluidIncompatData[strVal & "|" & drugid]

  Endif

  Return xx

End

Private Function GetLocalPrecaution(stockid As String, strCategory As String, strVal As String) As String

  Dim xx As String
  Dim res As Result
  Dim sql As String
  Dim codeid As String

  codeid = modMedConstant.GetCodeFromStockID(stockid)
  If strCategory = "MedicationReview/DrugAllergy" Then
    xx = modHelpVariable.GetCollectionValue(modTableCache.$CodeDrugAllergy, codeid & "|" & strVal, modBasic.$AppCacheDrugRelatedProblems)
    If Not xx Then
      sql = "select fldchemclass,fldreference from tblcode where fldcodename=&1 and fldchemclass=&2"
      res = modDatabase.$medConn.Exec(sql, codeid, strVal)
      If res.Available = True Then
        res.MoveLast
        xx = "ALLERGIC to drugs of " & res["fldchemclass"] & " [" & res["fldreference"] & "]"
        If modBasic.$AppCacheDrugRelatedProblems = "Yes" Then
          modTableCache.$CodeDrugAllergy.Add(xx, codeid & "|" & strVal)
        Endif
      Else
        xx = ""
      Endif
    Endif

  Else If strCategory = "MedicationReview/DiseaseContraindication" Then
    xx = modHelpVariable.GetCollectionValue(modTableCache.$CodeDiseaseContra, codeid & "|" & strVal, modBasic.$AppCacheDrugRelatedProblems)
    If Not xx Then
      sql = "select fldreference from tblmedcontraindication where fldparent=&1 and fldchild=&2"
      res = modDatabase.$medConn.Exec(sql, codeid, strVal)
      If res.Available = True Then
        res.MoveLast
        xx = "CONTRAINDICATED to " & strVal & " [" & res["fldreference"] & "]"
        If modBasic.$AppCacheDrugRelatedProblems = "Yes" Then
          modTableCache.$CodeDiseaseContra.Add(xx, codeid & "|" & strVal)
        Endif
      Else
        xx = ""
      Endif
    Endif

  Else If strCategory = "MedicationReview/SideEffects" Then
    xx = modHelpVariable.GetCollectionValue(modTableCache.$CodeAdverseRxn, codeid & "|" & strVal, modBasic.$AppCacheDrugRelatedProblems)
    If Not xx Then
      sql = "select fldtype,fldreference from tblmedadveffect where fldparent=&1 and fldchild=&2"
      res = modDatabase.$medConn.Exec(sql, codeid, strVal)
      If res.Available = True Then
        res.MoveLast
        xx = "Drug may WORSEN existing " & res["fldtype"] & " [" & res["fldreference"] & "]"
        If modBasic.$AppCacheDrugRelatedProblems = "Yes" Then
          modTableCache.$CodeAdverseRxn.Add(xx, codeid & "|" & strVal)
        Endif
      Else
        xx = ""
      Endif
    Endif

  Endif

  Return xx

End
