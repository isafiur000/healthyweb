Public Sub RenalPrecaution(cretclr As Float)

  Dim xColl As Collection
  Dim xWarn As String

  'renal impairment
  ' cretclr = modSysCons.GetCreatinineClearance($encid)
  ' If $RenalPrecaution = "Yes" Then
  If cretclr > 0 And If cretclr < 120 Then
    xWarn = GetMedicineReviewWarningMultiple($stockid, "MedicationReview/RenalPrecaution", CStr(cretclr))
    If xWarn Then

      xColl = New Collection
      xColl.Add("Renal Status", "Category")
      xColl.Add($codeid, "Drug")
      xColl.Add(cretclr & " mL/min", "Condition")
      xColl.Add(xWarn, "Warning")
      $xVar.Add(xColl)

    Endif
  Endif
  ' Endif

End

Public Sub AgeContraIndications(dtbirth As Date, dtrecord As Date)

  Dim xColl As Collection
  Dim ciage As Float

  'Age Contraindication
  ' If $AgeContraindication = "Yes" Then
  If dtbirth Then
    ciage = modMedConstant.GetContraIndicatedLowerAge($stockid)
    If ciage > 0 Then
      If DateDiff(dtbirth, dtrecord, gb.Year) < ciage Then

        xColl = New Collection
        xColl.Add("Age Contraindication", "Category")
        xColl.Add($codeid, "Drug")
        xColl.Add(CStr(DateDiff(dtbirth, dtrecord, gb.Year)) & " years", "Condition")
        xColl.Add(GetMedicineReviewWarning($stockid, "MedicationReview/AgeContraindication", ciage), "Warning")
        $xVar.Add(xColl)

      Endif
    Endif
  Endif
  ' Endif

End

Public Sub PreservativePrecaution(dtbirth As Date, dtrecord As Date)

  Dim xColl As Collection
  Dim presr As String

  'Preservative Precaution
  ' If $PreservativePrecaution = "Yes" Then
  If dtbirth Then
    presr = modMedConstant.GetPreservativeContent($stockid)
    If presr Then
      If DateDiff(dtbirth, dtrecord, gb.Month) < 6 Then

        xColl = New Collection
        xColl.Add("Preservatives", "Category")
        xColl.Add($stockid, "Drug")
        xColl.Add(CStr(DateDiff(dtbirth, dtrecord, gb.Month)) & " months", "Condition")
        xColl.Add(GetMedicineReviewWarning($stockid, "MedicationReview/PreservativePrecaution", presr), "Warning")
        $xVar.Add(xColl)

      Endif
    Endif
  Endif
  ' Endif

End

Public Sub DrugAllergy(sMedList As String[])

  Dim xmed As String
  Dim xColl As Collection
  Dim xWarn As String

  ' res = modDatabase.$myConn.Exec("select distinct(t1.fldcode) as fldcode from tblpatfindings as t1 inner join tblencounter as t2 on t1.fldencounterval=t2.fldencounterval where t1.fldtype=&1 and t2.fldpatientval=&2 and fldsave=&3", "Allergic Drugs", modPatient.GetPatientNoByEnc($encid), True)                                ''
  ' If $DrugAllergy = "Yes" Then
  If sMedList And If sMedList.Count Then
    For Each xmed In sMedList
      xWarn = GetLocalPrecaution($stockid, "MedicationReview/DrugAllergy", modMedConstant.GetChemicalClass(xmed))
      If xWarn Then
        xColl = New Collection
        xColl.Add("Drug Allergy", "Category")
        xColl.Add($codeid, "Drug")
        xColl.Add(xmed, "Condition")
        xColl.Add(xWarn, "Warning")
        $xVar.Add(xColl)

      Else If xmed = $codeid Then
        xColl = New Collection
        xColl.Add("Drug Allergy", "Category")
        xColl.Add($codeid, "Drug")
        xColl.Add(xmed, "Condition")
        xColl.Add("Allergic to " & $codeid, "Warning")
        $xVar.Add(xColl)
      Endif

    Next
  Endif
  ' Endif

End

