Public Sub btnmeddays_Click()

  Dim xval As Float
  Dim res As Result

  If GridView1.Selection.Count Then
    $rData.MoveTo(GridView1.Selection[0])
    If modGeneral.AllowClinicalEdit($rData["flduserid"]) = True Then
      xval = InputValue($rData["flditem"], ("Alter Duration"), $rData["flddays"])
      If xval >= 0 Then
        res = modDatabase.$myConn.Edit("tblinpatdosing", "fldid=&1 and fldencounterval=&2", $rData["fldid"], $encid)
        res["flddays"] = xval
        If xval Then
          res["fldendtime"] = DateAdd(res["fldstarttime"], gb.Hour, CInt(xval * 24))
        Endif
        res["xyz"] = False
        res.Update
        LoadMedicineGrid()
      Endif
    Endif
  Endif

End

