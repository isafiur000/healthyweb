Public Sub btnnewdose_Click()

  If btnnewdose.Text = "New" Then
    pnldosing.Visible = True
    pnlupdate.Visible = True
    btnnewdose.Text = "Hide"
  Else If btnnewdose.Text = "Hide" Then
    pnldosing.Visible = False
    pnlupdate.Visible = False
    btnnewdose.Text = "New"
  Endif

End

Public Sub btnrepeat_Click()

  Dim sColl As Collection
  Dim xLst As Long[]

  sColl = GetSetRegimen($encid)
  If sColl And If sColl.Count Then
    For Each xLst In sColl
      If sColl.Key = "New Regimen" Then
        AddNewRegimen(xLst)
      Else If sColl.Key = "Past Regimen" Then
        AddPastRegimens(xLst)
      Endif
    Next
  Endif

End

Private Sub AddNewRegimen(itmList As Long[])

  Dim idx As Long
  Dim res As Result
  Dim txprescriber As String
  Dim txpresno As String
  Dim xcurVal As String
  Dim xnarcotic As String[]
  Dim ygo As Boolean
  Dim xstart As Date

  If chknextplan.Value = True Then
    xcurVal = "Planned"
  Else
    xcurVal = "Continue"
  Endif
  xstart = DateAdd(Now(), gb.Hour, CInt(txtstart.Value))

  If itmList And If itmList.Count Then
    If modMisc.AllowDiagnoBilling($encid) = True Then

      For Each idx In itmList
        res = modDatabase.$myConn.Exec("select fldroute,fldbrandid,flddose,fldfreq,fldday,fldqty,fldusage from tblmedregimen where fldid=&1", idx)
        If res.Available Then
          ygo = False
          If modBasic.$ClinicDisableMedicines.Exist(res["fldbrandid"]) = True Then
            ygo = False
          Else
            ygo = True
          Endif
          If ygo = True Then

            If modMedConstant.GetNarcoticType(res["fldbrandid"]) = "Yes" Then
              txprescriber = $NarcoDoctor
              txpresno = $NarcoRegd
              If Not txpresno Then
                xnarcotic = DualGridValue(("Select Narcotic Prescriber"), $ClinicianLst, False)
                If xnarcotic Then
                  txprescriber = xnarcotic[1]
                  txpresno = xnarcotic[0]
                Endif
              Endif
              If txprescriber And If txpresno Then
                modPharmSub.InsertIPMedicineEntry($encid, res["fldroute"], res["fldbrandid"], res["flddose"], res["fldfreq"], res["fldday"], res["fldqty"], txprescriber, txpresno, xstart, "", res["fldusage"], 0, xcurVal)
              Endif
            Else
              modPharmSub.InsertIPMedicineEntry($encid, res["fldroute"], res["fldbrandid"], res["flddose"], res["fldfreq"], res["fldday"], res["fldqty"], "", "", xstart, "", res["fldusage"], 0, xcurVal)
            Endif

          Endif
        Endif
      Next
      LoadMedicineGrid()
      ShowAdmixtures()

    Else
      Message.Warning("Diagnosis not provided", ("OK"))
    Endif
  Endif

End

Private Sub AddPastRegimens(itmList As Long[])

  Dim idx As Long
  Dim res As Result
  Dim txprescriber As String
  Dim txpresno As String
  Dim xcurVal As String
  Dim xnarcotic As String[]
  Dim ygo As Boolean

  If chknextplan.Value = True Then
    xcurVal = "Planned"
  Else
    xcurVal = "Continue"
  Endif

  If itmList And If itmList.Count Then
    If modMisc.AllowDiagnoBilling($encid) = True Then

      For Each idx In itmList
        res = modDatabase.$myConn.Exec("select fldroute,flditem,flddose,fldfreq,flddays,fldqtydisp,flddirection from tblpatdosing where fldid=&1", idx)
        If res.Available Then
          ygo = False
          If modBasic.$ClinicDisableMedicines.Exist(res["flditem"]) = True Then
            ygo = False
          Else
            ygo = True
          Endif
          If ygo = True Then

            If modMedConstant.GetNarcoticType(res["flditem"]) = "Yes" Then
              txprescriber = $NarcoDoctor
              txpresno = $NarcoRegd
              If Not txpresno Then
                xnarcotic = DualGridValue(("Select Narcotic Prescriber"), $ClinicianLst, False)
                If xnarcotic Then
                  txprescriber = xnarcotic[1]
                  txpresno = xnarcotic[0]
                Endif
              Endif
              If txprescriber And If txpresno Then
                modPharmSub.InsertIPMedicineEntry($encid, res["fldroute"], res["flditem"], res["flddose"], res["fldfreq"], res["flddays"], res["fldqtydisp"], txprescriber, txpresno, DateAdd(Now(), gb.Hour, CInt(txtstart.Value)), "", res["flddirection"], 0, xcurVal)
              Endif
            Else
              modPharmSub.InsertIPMedicineEntry($encid, res["fldroute"], res["flditem"], res["flddose"], res["fldfreq"], res["flddays"], res["fldqtydisp"], "", "", DateAdd(Now(), gb.Hour, CInt(txtstart.Value)), "", res["flddirection"], 0, xcurVal)
            Endif

          Endif
        Endif
      Next
      LoadMedicineGrid()
      ShowAdmixtures()

    Else
      Message.Warning("Diagnosis not provided", ("OK"))
    Endif
  Endif

End

Public Sub btngroup_Click()

  Dim xList As Long[]
  Dim xIndex As Long

  Dim res As Result
  Dim txprescriber As String
  Dim txpresno As String
  Dim xdose As Float
  Dim xcurVal As String
  Dim xnarcotic As String[]
  Dim ygo As Boolean

  If chknextplan.Value = True Then
    xcurVal = "Planned"
  Else
    xcurVal = "Continue"
  Endif

  If modMisc.AllowDiagnoBilling($encid) = True Then
    xList = GetSetProtocol($encid)
    If xList And If xList.Count Then

      For Each xIndex In xList
        res = modDatabase.$myConn.Exec("select fldroute,flditem,flddose,flddoseunit,fldfreq,fldday,fldqty,fldstart,fldadvice from tblproductgroup where fldid=&1 and (fldcomp=&2 or fldcomp=&3)", xIndex, modBasic.$compID, "%")
        If res.Available Then
          ygo = False
          If modBasic.$ClinicDisableMedicines.Exist(res["flditem"]) = True Then
            ygo = False
          Else
            ygo = True
          Endif
          If ygo = True Then

            xdose = modMedDosing.GetDoseInMg(res["flddose"], res["flddoseunit"], $encid)
            If xdose Then
              If modMedConstant.GetNarcoticType(res["flditem"]) = "Yes" Then
                txprescriber = $NarcoDoctor
                txpresno = $NarcoRegd
                If Not txpresno Then
                  xnarcotic = DualGridValue(("Select Narcotic Prescriber"), $ClinicianLst, False)
                  If xnarcotic Then
                    txprescriber = xnarcotic[1]
                    txpresno = xnarcotic[0]
                  Endif
                Endif
                If txprescriber And If txpresno Then
                  modPharmSub.InsertIPMedicineEntry($encid, res["fldroute"], res["flditem"], xdose, res["fldfreq"], res["fldday"], res["fldqty"], txprescriber, txpresno, DateAdd(Now(), gb.Hour, res["fldstart"]), "", res["fldadvice"], 0, xcurVal)
                Endif
              Else
                modPharmSub.InsertIPMedicineEntry($encid, res["fldroute"], res["flditem"], xdose, res["fldfreq"], res["fldday"], res["fldqty"], "", "", DateAdd(Now(), gb.Hour, res["fldstart"]), "", res["fldadvice"], 0, xcurVal)
              Endif
            Endif

          Endif
        Endif
      Next
      LoadMedicineGrid()
      ShowAdmixtures()

    Endif
  Else
    Message.Warning("Diagnosis not provided", ("OK"))
  Endif

End

''-------------------------- Create Orders -------------------------
Public Sub btndispown_Click()

  Dim Row As Integer
  Dim res As Result

  Dim xtax As Float
  Dim xdisc As Float
  Dim itemtype As String
  Dim xfixrate As Float
  Dim xfixname As String
  Dim itemmode As String
  Dim CPharmFix As CFixRatePharmacy
  Dim xgo As Boolean
  Dim xallow As Boolean
  Dim xflvool As Float
  Dim xflrate As Float

  For Row = 0 To GridView1.Count - 1
    If GridView1.IsSelected(Row) Then
      $rData.MoveTo(Row)
      res = modDatabase.$myConn.Exec("select fldid,fldroute,flditem,flddose,fldfreq,flddays,fldqtyorder,fldprescriber,fldregno,flddirection,fldadminsite,fldmixing,fldstarttime,fldendtime,fldmixvolume,fldmixrate from tblinpatdosing where fldid=&1 and fldencounterval=&2 and fldcurval=&3 and fldsave=&4", $rData["fldid"], $encid, "Continue", False)                 ''
      If res.Available Then

        If res["fldmixvolume"] Then
          xflvool = res["fldmixvolume"]
        Else
          xflvool = 0
        Endif
        If res["fldmixrate"] Then
          xflrate = res["fldmixrate"]
        Else
          xflrate = 0
        Endif
        xallow = False
        If res["fldendtime"] >= modDate.StartSqlDate(Now()) Then
          xallow = True
        Else If res["flddays"] = 0 Then
          xallow = True
        Endif

        If xallow = True Then

          itemtype = modNonMedical.GetBillItemCategoryFromCombo(res["fldroute"])
          xgo = False
          If modBasic.$BillPharmFixedModes.Exist($sBillMode) = True Then
            CPharmFix = New CFixRatePharmacy(itemtype, res["flditem"], $sBillMode)
            xfixrate = CPharmFix.GetFixRate()
            xfixname = CPharmFix.GetFixItem()
            If xfixname Then
              xgo = True
            Else
              xgo = False
            Endif
          Else
            xgo = True
          Endif

          If xgo = True Then
            itemmode = $sBillMode
            xtax = modNonMedical.ShowTaxValues(itemtype, res["flditem"])
            xdisc = modNonMedical.DiscPercentForCategoryValue($encid, cmbdisctype.Text, itemtype, res["flditem"], itemmode)
            modPharmSub.InsertDosingMedicine($encid, $xBillType, $sBillMode, cmbdisctype.Text, $LedgerAC, res["fldroute"], res["flditem"], res["flddose"], res["fldfreq"], res["flddays"], res["fldqtyorder"], $status, res["fldprescriber"], res["fldregno"], Now(), xtax, xdisc, xfixname, xfixrate, "Request", "IPD", res["flddirection"], 0, res["fldid"], "Continue", res["fldadminsite"], res["fldmixing"], xflrate, xflvool)               ''
            GridView1.Unselect(Row)
          Endif

        Endif
      Endif
    Endif
  Next
  Me.Exec(Subst("Toastify({text: '&1', duration: &2}).showToast()", "Information saved", modBasic.$BalloonDelay))

End

''---------- New entry manual -----------------
Private Sub BlankDosingBox()

  cmbroute.Text = ""
  cmbmedicine.Text = ""
  txtdose.Value = 0
  If modBasic.$AppSelect2JS = "Enable" Then
    modJavaScript.TriggerSelect2Combo(cmbfreq)
  Endif
  cmbfreq.Text = ""
  txtday.Tag = ""
  txtday.Value = 0
  txtqty.Tag = ""
  txtqty.Value = 0
  txtdirection.Text = ""
  $HideDos = False
  lbldose.Text = ""
  lblregimen.Text = ""

End

Private Function GetBrandGenerricType() As String

  Dim brandOrGeneric As String

  If rbrand.Value = True Then
    brandOrGeneric = "Brand"
  Else
    brandOrGeneric = "Generic"
  Endif
  Return brandOrGeneric

End

Private Sub RegimenBoxSetting(sBool As Boolean)

  txtdose.Enabled = sBool
  cmbfreq.Enabled = sBool
  txtday.Enabled = sBool

End

Public Sub cmbroute_Click()

  cmbmedicine.Text = ""
  RegimenBoxSetting(True)
  If modBasic.$TabletModeEnable = "Yes" Then
  Else
    cmbmedicine.SetFocus
  Endif

End

Private Function GetPharmTarget(sRoute As String) As String

  Dim xtarg As String

  Select sRoute
    Case "msurg"
      xtarg = modBasic.$BillTargetSurgical
    Case "suture"
      xtarg = modBasic.$BillTargetSutures
    Case "ortho"
      xtarg = modBasic.$BillTargetOrthopedics
    Case "extra"
      xtarg = modBasic.$BillTargetExtras
    Case Else
      xtarg = modBasic.$BillTargetMedicine
  End Select

  Return xtarg

End

Private Function GetMedicineList() As String[]

  Dim res As Result
  Dim xlist As String[]

  If cmbroute.Text = "suture" Or If cmbroute.Text = "msurg" Or If cmbroute.Text = "ortho" Or If cmbroute.Text = "extra" Then
    If chkout.Value = True Then
      res = modStock.ItemListForPurchaseBillMode(cmbroute.Text, GetBrandGenerricType(), $sBillMode)
    Else
      If modBasic.$ClinLockPharmStock = "Enable" Then
        res = modStock.FillMedicinesDispensingComboResult(cmbroute.Text, GetBrandGenerricType(), GetPharmTarget(cmbroute.Text), $sBillMode)
      Else
        res = modStock.FillMedicinesPrescribingComboResult(cmbroute.Text, GetBrandGenerricType(), $sBillMode)
      Endif
    Endif
    xlist = modControlSub.GetDirectFillresult(res)
  Else
    If chkout.Value = True Then
      res = modStock.ItemListForPurchaseBillMode(cmbroute.Text, GetBrandGenerricType(), $sBillMode)
    Else
      If modBasic.$ClinLockPharmStock = "Enable" Then
        res = modStock.FillMedicinesDispensingComboResult(cmbroute.Text, GetBrandGenerricType(), GetPharmTarget(cmbroute.Text), $sBillMode)
      Else
        res = modStock.FillMedicinesPrescribingComboResult(cmbroute.Text, GetBrandGenerricType(), $sBillMode)
      Endif
    Endif
    xlist = modControlSub.GetDirectFillresult(res)
  Endif

  Return xlist

End

Public Sub cmbmedicine_Completion(Text As String)

  Dim xallLst As String[]
  Dim xList As String[]

  xallLst = GetMedicineList()
  If xallLst And If xallLst.Count Then
    xList = modString.SelectStringArrayToText(Text, xallLst, False)
    cmbmedicine.CompleteWith(xList)
  Endif

End

Public Sub btnmedlist_Click()

  Dim xlist As String[]
  Dim xlist1 As String[]
  Dim aList As String[]
  Dim aList1 As String[]

  xlist = GetMedicineList()
  If xlist Then
    If cmbroute.Text = "suture" Or If cmbroute.Text = "msurg" Or If cmbroute.Text = "ortho" Or If cmbroute.Text = "extra" Then
      cmbmedicine.Text = GridViewNew("Select Particulars", xlist, False)
    Else
      If modBasic.$ClinCategoryGrid = "Yes" Then
        xlist1 = modMedConstant.GetStockIDWithCategory(xlist)
        If xlist1 Then
          If modBasic.$ClinicDisableMedicines And If modBasic.$ClinicDisableMedicines.Count Then
            aList1 = modString.GetRemainingArray(xlist1, modBasic.$ClinicDisableMedicines)
            cmbmedicine.Text = GridViewGroup("Select Medicine", aList1, False)
          Else
            cmbmedicine.Text = GridViewGroup("Select Medicine", xlist1, False)
          Endif
        Endif
      Else
        If modBasic.$ClinicDisableMedicines And If modBasic.$ClinicDisableMedicines.Count Then
          aList = modString.GetRemainingArray(xlist, modBasic.$ClinicDisableMedicines)
          cmbmedicine.Text = GridViewNew("Select Particulars", aList, False)
        Else
          cmbmedicine.Text = GridViewNew("Select Particulars", xlist, False)
        Endif
      Endif
    Endif
  Endif
  CheckMedicineName()

End

Private Sub CheckMedicineName()
  ' ' Dim hForm As FmDiseaseDose

  Dim cForm As CRecommendDosing

  If cmbmedicine.Text Then
    If cmbroute.Text = "suture" Or If cmbroute.Text = "msurg" Or If cmbroute.Text = "ortho" Or If cmbroute.Text = "extra" Then
      RegimenBoxSetting(False)
      txtqty.SetFocus
      Me.Exec("$_(" & JS(txtqty.Name & ":entry") & ").select()")
    Else
      If rbrand.Value = True Then
        cmbmedicine.Text = modMedConstant.ConvertBrandToGeneric(cmbroute.Text, cmbmedicine.Text)
      Endif
      RegimenBoxSetting(True)
      lbldose.Text = modMedConstant.GetDrugDosingUnit(cmbmedicine.Text)

      If modBasic.$MedDoseRecommend = "No" Then
      Else
        cForm = New CRecommendDosing($encid, $PatAge, cmbmedicine.Text)
        txtdose.Value = cForm.UnitDose()
        cmbfreq.Text = cForm.Frequency()
        lblregimen.Text = cForm.Regimen()
      Endif

      Select cmbroute.Text
        Case "CIV", "CIn(Epid)", "CIn(Block)"
          cmbfreq.Text = "Continuous"
        Case Else
          If modBasic.$ClinDefaultFreq Then
            cmbfreq.Text = modBasic.$ClinDefaultFreq
          Endif
      End Select

      ' '   If modBasic.$MedDiseaseDose Then
      ' '     If modBasic.$MedDiseaseDose = "None" Then
      ' '     Else
      ' '       hForm = New FmDiseaseDose(modBasic.$MedDiseaseDose, $encid, cmbroute.Text, cmbmedicine.Text, txtdose, cmbfreq, txtday)
      ' '       hForm.ShowModal
      ' '     Endif
      ' '   Endif

      txtdose.SetFocus()
      Me.Exec("$_(" & JS(txtdose.Name & ":entry") & ").select()")
    Endif
  Endif

End

Public Sub cmbmedicine_Activate()

  If Not cmbroute.Text Then
    cmbroute.SetFocus
  Else If cmbroute.Text Then
    If Not cmbmedicine.Text Then
      btnmedlist_Click()
    Else
      CheckMedicineName()
    Endif
  Endif

End

