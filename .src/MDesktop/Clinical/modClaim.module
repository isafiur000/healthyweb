''================================== Daily Format ==============================
Private Sub ShowOnlyClaimReport(encid As String, xstatus As String) As String

  Dim dfirdate As Date
  Dim dlstdate As Date
  Dim res1 As Result
  Dim res2 As Result
  Dim xclaim As String
  Dim xpatno As String

  If xstatus = "Consultation" Then
    xpatno = modPatient.GetPatientNoByEnc(encid)
    dfirdate = modDate.StartSqlDate(Now())
    dlstdate = moddate.EndSqlDate(Now())
    res1 = modDatabase.$myConn.Exec("select t1.fldclaimid as fldclaimid,t1.fldclaimcode as fldclaimcode from tblclaimcode as t1 inner join tblencounter as t2 ON t1.fldencounterval=t2.fldencounterval where t2.fldpatientval=&1 and t1.fldtime>=&2 and t1.fldtime<=&3 and t1.fldstatus=&4 and t1.fldclaimid IS NOT NULL ORDER BY t1.fldtime", xpatno, dfirdate, dlstdate, "Consultation")
    If res1.Available Then
      res1.MoveLast
      If res1["fldclaimcode"] Then
        xclaim = res1["fldclaimcode"]
      Else
        If res1["fldclaimid"] Then
          xclaim = res1["fldclaimid"]
        Else
          xclaim = ""
        Endif
      Endif
    Else
      res2 = modDatabase.$myConn.Exec("select fldclaimid,fldclaimcode from tblclaimcode where fldencounterval=&1 and fldtime>=&2 and fldtime<=&3 and fldstatus=&4 and fldclaimid IS NOT NULL", encid, dfirdate, dlstdate, "Consultation")
      If res2.Available Then
        res2.MoveLast
        If res2["fldclaimcode"] Then
          xclaim = res2["fldclaimcode"]
        Else
          If res2["fldclaimid"] Then
            xclaim = res2["fldclaimid"]
          Else
            xclaim = ""
          Endif
        Endif
      Else
        xclaim = ""
      Endif
    Endif  ''end of consultation

  Else If xstatus = "Emergency" Then
    dfirdate = moddate.StartSqlDate(DateAdd(Now(), gb.Hour, -72))
    dlstdate = moddate.EndSqlDate(Now())
    res1 = modDatabase.$myConn.Exec("select fldclaimid,fldclaimcode from tblclaimcode where fldencounterval=&1 and fldtime>=&2 and fldtime<=&3 and fldstatus=&4 and fldclaimid IS NOT NULL ORDER BY fldtime", encid, dfirdate, dlstdate, xstatus)
    If res1.Available Then
      res1.MoveLast
      If res1["fldclaimcode"] Then
        xclaim = res1["fldclaimcode"]
      Else
        If res1["fldclaimid"] Then
          xclaim = res1["fldclaimid"]
        Else
          xclaim = ""
        Endif
      Endif
    Else
      xclaim = ""
    Endif

  Else
    res1 = modDatabase.$myConn.Exec("select fldclaimid,fldclaimcode from tblclaimcode where fldencounterval=&1 and fldstatus=&2", encid, "Patient Ward")
    If res1.Available Then
      res1.MoveLast
      If res1["fldclaimcode"] Then
        xclaim = res1["fldclaimcode"]
      Else
        If res1["fldclaimid"] Then
          xclaim = res1["fldclaimid"]
        Else
          xclaim = ""
        Endif
      Endif
    Else
      xclaim = ""
    Endif

  Endif

  Return xclaim

End

Private Sub ShowOnlyClaimNew(encid As String, xstatus As String) As String

  Dim dfirdate As Date
  Dim dlstdate As Date
  Dim res1 As Result
  Dim res2 As Result
  Dim xclaim As String
  Dim xpatno As String

  If xstatus = "Consultation" Then
    xpatno = modPatient.GetPatientNoByEnc(encid)
    dfirdate = modDate.StartSqlDate(Now())
    dlstdate = moddate.EndSqlDate(Now())
    res1 = modDatabase.$myConn.Exec("select t1.fldclaimid as fldclaimid from tblclaimcode as t1 inner join tblencounter as t2 ON t1.fldencounterval=t2.fldencounterval where t2.fldpatientval=&1 and t1.fldtime>=&2 and t1.fldtime<=&3 and t1.fldstatus=&4 and t1.fldclaimid IS NOT NULL ORDER BY t1.fldtime", xpatno, dfirdate, dlstdate, "Consultation")
    If res1.Available Then
      res1.MoveLast
      If res1["fldclaimid"] Then
        xclaim = res1["fldclaimid"]
      Else
        xclaim = ""
      Endif
    Else
      res2 = modDatabase.$myConn.Exec("select fldclaimid from tblclaimcode where fldencounterval=&1 and fldtime>=&2 and fldtime<=&3 and fldstatus=&4 and fldclaimid IS NOT NULL", encid, dfirdate, dlstdate, "Consultation")
      If res2.Available Then
        res2.MoveLast
        If res2["fldclaimid"] Then
          xclaim = res2["fldclaimid"]
        Else
          xclaim = ""
        Endif
      Else
        xclaim = ""
      Endif
    Endif  ''end of consultation

  Else If xstatus = "Emergency" Then
    dfirdate = moddate.StartSqlDate(DateAdd(Now(), gb.Hour, -72))
    dlstdate = moddate.EndSqlDate(Now())
    res1 = modDatabase.$myConn.Exec("select fldclaimid from tblclaimcode where fldencounterval=&1 and fldtime>=&2 and fldtime<=&3 and fldstatus=&4 and fldclaimid IS NOT NULL ORDER BY fldtime", encid, dfirdate, dlstdate, xstatus)
    If res1.Available Then
      res1.MoveLast
      If res1["fldclaimid"] Then
        xclaim = res1["fldclaimid"]
      Else
        xclaim = ""
      Endif
    Else
      xclaim = ""
    Endif

  Else
    res1 = modDatabase.$myConn.Exec("select fldclaimid from tblclaimcode where fldencounterval=&1 and fldstatus=&2", encid, "Patient Ward")
    If res1.Available Then
      res1.MoveLast
      If res1["fldclaimid"] Then
        xclaim = res1["fldclaimid"]
      Else
        xclaim = ""
      Endif
    Else
      xclaim = ""
    Endif

  Endif

  Return xclaim

End

Private Sub ShowCreateClaimNew(encid As String, xstatus As String, Optional sType As String) As String

  Dim dfirdate As Date
  Dim dlstdate As Date
  Dim res1 As Result

  Dim xclaim As String
  Dim xpatno As String
  Dim xregist As Date
  Dim xType As String

  If sType Then
    xType = sType
  Else
    xType = ""
  Endif

  If xstatus = "Consultation" Then
    xpatno = modPatient.GetPatientNoByEnc(encid)
    dfirdate = modDate.StartSqlDate(Now())
    dlstdate = moddate.EndSqlDate(Now())
    res1 = modDatabase.$myConn.Exec("select t1.fldclaimid as fldclaimid from tblclaimcode as t1 inner join tblencounter as t2 ON t1.fldencounterval=t2.fldencounterval where t2.fldpatientval=&1 and t1.fldtime>=&2 and t1.fldtime<=&3 and t1.fldstatus=&4 and t1.fldclaimid IS NOT NULL ORDER BY t1.fldtime", xpatno, dfirdate, dlstdate, "Consultation")
    If res1.Available Then
      res1.MoveLast
      xclaim = res1["fldclaimid"]
    Else
      xregist = modDate.StartSqlDate(modPatient.GetRecordDate(encid))
      If DateAdd(xregist, gb.day, 7) >= modDate.StartSqlDate(Now()) Then
        xclaim = GetNewClaimCode(encid, xType)
      Endif
    Endif

  Else If xstatus = "Emergency" Then
    dfirdate = moddate.StartSqlDate(DateAdd(Now(), gb.Hour, -72))
    dlstdate = moddate.EndSqlDate(Now())
    res1 = modDatabase.$myConn.Exec("select fldclaimid from tblclaimcode where fldencounterval=&1 and fldtime>=&2 and fldtime<=&3 and fldstatus=&4 and fldclaimid IS NOT NULL ORDER BY fldtime", encid, dfirdate, dlstdate, "Emergency")
    If res1.Available Then
      res1.MoveLast
      xclaim = res1["fldclaimid"]
    Else
      xclaim = GetNewClaimCode(encid, xType)
    Endif

  Else
    res1 = modDatabase.$myConn.Exec("select fldclaimid from tblclaimcode where fldencounterval=&1 and fldstatus=&2", encid, "Patient Ward")
    If res1.Available Then
      res1.MoveLast
      xclaim = res1["fldclaimid"]
    Else
      xclaim = GetNewClaimCode(encid, xType)
    Endif
  Endif

  Return xclaim

End

''------------------ Variables ------------------
Public Function GetHIClaimState(sReference As String) As String

  Dim res As Result
  Dim xstate As String

  res = modDatabase.$myConn.Exec("select fldstatus from tblclaimcode where fldclaimid=&1", sReference)
  If res.Available Then
    If res["fldstatus"] Then
      xstate = res["fldstatus"]
    Else
      xstate = ""
    Endif
  Else
    xstate = ""
  Endif
  Return xstate

End

Public Function GetHIClaimTime(sReference As String) As Date

  Dim res As Result
  Dim xstate As Date

  res = modDatabase.$myConn.Exec("select fldtime from tblclaimcode where fldclaimid=&1", sReference)
  If res.Available Then
    If res["fldtime"] Then
      xstate = res["fldtime"]
    Else
      xstate = ""
    Endif
  Else
    xstate = ""
  Endif
  Return xstate

End

Public Function GetChronicClaimStatus(encid As String) As Boolean

  Dim res As Result
  Dim xType As Boolean

  xType = False
  If modBasic.$HIChronicList And If modBasic.$HIChronicList.Count Then
    res = modDatabase.$myConn.Exec("select fldcodenew from tblpatfindings where fldencounterval=&1 and fldsave=&2", encid, True)
    If res.Available Then
      For Each res
        If modBasic.$HIChronicList.Exist(res["fldcodenew"]) = True Then
          xType = True
          Break
        Endif
      Next
    Else
      xType = False
    Endif

  Else
    xType = False
  Endif

  Return xType

End
