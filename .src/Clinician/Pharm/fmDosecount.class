' Gambas class file

Private $encid As String
Private $DiscPackage As String
Private $useCardex As Boolean
Private $sTatus As String

Private $LedgerAC As String
Private $xBillType As String
Private $sBillMode As String
Private $sClaimState As String
Private $ClaimCode As String

Private $rData1 As Result
Private $aMyFields1 As String[]
Private $rData As Result
Private $aMyFields As String[]

Private $xNHISCode As String
Private $HiCappingVar As Collection

Public Sub _new(encid As String, DiscPackage As String, useCardex As Boolean, sClass As String)

  Dim accLst As String[]

  $encid = encid
  $DiscPackage = DiscPackage
  $useCardex = useCardex
  WebContainer1.Class = sClass

  $xNHISCode = modPatient.GetPatientExtCOdebyEnc($encid)
  $sTatus = modPatient.CurrentAdmissionStatus($encid)
  accLst = modNonMedical.GetHigherCostSchemes(modBasic.$BillDiscountCash, $DiscPackage)
  If accLst.Count = 0 Then
    accLst.Add($DiscPackage)
  Endif
  cmbdisctype.List = accLst
  cmbdisctype.Text = $DiscPackage
  If modNonMedical.GetAutoBillingLock($encid, $DiscPackage) = True Then
    cmbdisctype.Enabled = False
  Endif
  ShowBillingParam($DiscPackage)
  FillMedicineList()
  ' ListBox1.SetFocus

End

Public Sub SetEntryControls(xBool As Boolean)

  btnreceive.Enabled = xBool
  btnsave.Enabled = xBool
  btndoseedit.Enabled = xBool
  btndosestop.Enabled = xBool

End

Public Sub cmbdisctype_Click()

  If cmbdisctype.Text Then
    ShowBillingParam(cmbdisctype.Text)
  Endif

End

Private Sub ShowBillingParam(sDisctype As String)

  Dim hForm As CPackageParams

  $HiCappingVar = New Collection
  hForm = New CPackageParams($encid, sDisctype)
  $sBillMode = hForm.GetBillingMode()
  $LedgerAC = hForm.GetLedgerAC()
  $xBillType = hForm.GetBillType()
  $ClaimCode = hForm.GetClaimCode()
  $sClaimState = hForm.GetClaimState()

End

Private Sub GetHImedicineCappingVar()

  Dim hForm As CimisAPICap

  If cmbdisctype.Text = modBasic.$HIPackage Or If cmbdisctype.Text = modBasic.$HIPackageER Then
    If modBasic.$IMISValidateURL Then

      If modClaim.GetChronicClaimStatus($encid) = True Then
        If $HiCappingVar.Count Then
          $HiCappingVar.Clear()
        Endif
      Else
        If Not $HiCappingVar.Count Then
          hForm = New CimisAPICap($xNHISCode)
          $HiCappingVar = hForm.GetMedicineLimits()
        Endif

        If Not $HiCappingVar.Count Then
          $HiCappingVar = modClaim.GetClaimCappingLimit($encid, $ClaimCode)
        Endif

      Endif

    Endif
  Endif

End

Public Sub RefreshList()

  FillMedicineList()

End

Private Sub FillMedicineList()

  Dim sql1 As String
  Dim sql2 As String

  If $useCardex = True Then
    sql1 = "select flditem,fldid,fldroute,flditem,flddose,fldfreq,flddays,fldcurval,flddirection,fldmixing,flddosecount,fldqtyorder,flduserid,fldid from tblinpatdosing where fldencounterval=&1 and fldstarttime<=&2 and fldendtime>=&3 and fldroute<>&4 and fldcurval=&5 and flddose>&6 and flddays>&6"                    ''
    sql2 = "select flditem,fldid,fldroute,flditem,flddose,fldfreq,flddays,fldcurval,flddirection,fldmixing,flddosecount,fldqtyorder,flduserid,fldid from tblinpatdosing where fldencounterval=&1 and fldroute<>&4 and fldcurval=&5 and flddose>&6 and flddays=&6"
    $rData1 = modDatabase.$myConn.Exec(sql1 & " UNION ALL " & sql2, $encid, Now(), DateAdd(Now(), gb.Hour, -3), "fluid", "Continue", 0)
  Else
    sql1 = "select fldsave_order,fldid,fldroute,flditem,flddose,fldfreq,flddays,fldstatus,flddirection,fldmixing,flddosecount,fldqtydisp,flduserid_order,flditemno from tblpatdosing where fldencounterval=&1 and fldsave_order=&2 and fldstarttime<=&3 and fldendtime>=&4 and fldroute<>&5 and flditemtype=&6 and fldcurval=&7 and flddose>&8 and fldqtydisp>fldqtyret"                    ''
    sql2 = "select fldsave_order,fldid,fldroute,flditem,flddose,fldfreq,flddays,fldstatus,flddirection,fldmixing,flddosecount,fldqtydisp,flduserid_order,flditemno from tblpatdosing where fldencounterval=&1 and fldsave_order=&9 and fldstarttime<=&3 and DATE_ADD(fldstarttime, INTERVAL flddays DAY)>=&4 and fldroute<>&5 and flditemtype=&6 and fldcurval=&7 and flddose>&8 and fldqtydisp>fldqtyret"
    $rData1 = modDatabase.$myConn.Exec(sql1 & " UNION ALL " & sql2, $encid, True, Now(), DateAdd(Now(), gb.Hour, -3), "fluid", "Medicines", "Continue", 0, False)
  Endif
  $aMyFields1 = New String[]
  modGridView.ReadSmallData(GridView2, $rData1, $aMyFields1)
  With GridView2
    .Columns[0].Width = CStr(20 * modBasic.$AppWidthRatio) & "px"
    .Columns[1].Hidden = True
    .Columns[2].Hidden = True
    .Columns[3].Expand = True
    .Columns[4].Hidden = True
    .Columns[5].Hidden = True
    .Columns[6].Hidden = True
    .Columns[7].Hidden = True
    .Columns[8].Hidden = True
    .Columns[9].Hidden = True
    .Columns[10].Hidden = True
    .Columns[11].Hidden = True
    .Columns[12].Hidden = True
    .Columns[13].Hidden = True
  End With

End

Public Sub GridView2_Data(Row As Integer, Column As Integer, Data As WebTableData)

  $rData1.MoveTo(Row)
  modGridView.GridViewDecoration(Data, Row)
  If Column = 0 Then
    If $useCardex = True Then
      Data.Html = modString.GetImageForHTMLGrid(GetMedCardex($encid, $rData1[$aMyFields1[Column]]), "50%", "auto")
    Else
      Data.Html = modString.GetImageForHTMLGrid(GetMedStatus($rData1[$aMyFields1[Column]]), "50%", "auto")
    Endif
    Data.Text = ""
  Else
    Data.Text = $rData1[$aMyFields1[Column]]
  Endif

End

Private Function GetMedCardex(encid As String, xStockId As String) As String

  Dim xtot As Float
  Dim xadmn As Float
  Dim xicon As String

  If xStockId Then
    xtot = modPharmacy.GetCardexDispensedQTY(encid, xStockId)
    xadmn = modPharmacy.GetCardexAdministerQTY(encid, xStockId)
    If xtot > xadmn Then
      xicon = "/" &/ Application.Root &/ "icons/coll4.png"
    Else
      xicon = "/" &/ Application.Root &/ "icons/coll5.png"
    Endif
  Else
    xicon = ""
  Endif

  Return xicon

End

Private Function GetMedStatus(sBool As Boolean) As String

  Dim xicon As String

  If sBool = True Then
    xicon = "/" &/ Application.Root &/ "icons/coll4.png"
  Else If sBool = False Then
    xicon = "/" &/ Application.Root &/ "icons/coll5.png"
  Endif

  Return xicon

End

Public Sub GridView2_Select()

  If $useCardex = True Then
    ShowSelectedCardex()
  Else
    ShowSelectedDosing()
  Endif

End

Private Sub ShowSelectedCardex()

  Dim xtot As Float
  Dim xadmn As Float
  Dim xpos As Boolean

  chkuselocal.Value = False
  If GridView2.Selection.Count Then
    $rData1.MoveTo(GridView2.Selection[0])
    If $rData1["fldid"] Then
      txtid.Value = $rData1["fldid"]
      txtcardex.Value = $rData1["fldid"]
    Else
      txtid.Value = 0
      txtcardex.Value = 0
    Endif
    lblmedicine.Text = $rData1["flditem"]
    txtordose.Value = $rData1["flddose"]
    txtorfreq.Text = $rData1["fldfreq"]
    txtmedname.Text = modMedConstant.GetDrugFromStockID(lblmedicine.Text)

    xtot = modPharmacy.GetCardexDispensedQTY($encid, $rData1["flditem"])
    xadmn = modPharmacy.GetCardexAdministerQTY($encid, $rData1["flditem"])
    If xtot > xadmn Then
      xpos = True
    Else
      xpos = False
    Endif
    If xpos = False Then
      chkdisp.Value = False
      pnlocal.Visible = True
      txttransqty.Value = $rData1["fldqtyorder"]
    Else
      chkdisp.Value = True
      txttransqty.Value = 0
      pnlocal.Visible = False
    Endif

    btninjection.Tag = $rData1["fldroute"]
    txtinitstren.Value = modMedConstant.GetDrugInitialStrength($rData1["flditem"])
    lblregimen.Text = $rData1["fldroute"] & Space(2) & $rData1["flddose"] & Space(1) & modMedConstant.GetMedicineDoseUnit($rData1["flditem"]) & " X " & $rData1["fldfreq"] & " X " & $rData1["flddays"] & " day(s)"
    lblregimen.Tag = $rData1["fldfreq"]

    If $rData1["flddirection"] Then
      pnldirection.Visible = True
      txtdirection.Html = "<p>" & $rData1["flddirection"] & "</p>"
    Else
      pnldirection.Visible = False
    Endif
    If $rData1["fldmixing"] Then
      pnlmixture.Visible = True
      txtmixture.Html = $rData1["fldmixing"]
    Else
      pnlmixture.Visible = False
    Endif
    If txtcardex.Value Then
      lblregimen.Text = lblregimen.Text & " [" & modGeneral.GetUserFullName(modPharmacy.GetInpatPrescriber($encid, txtcardex.Value)) & "]"
    Else
      lblregimen.Text = lblregimen.Text & " [" & modGeneral.GetUserFullName($rData1["flduserid_order"]) & "]"
    Endif
    Select $rData1["fldroute"]
      Case "fluid", "CIV", "CIn(Epid)", "CIn(Block)"
        lblunit.Text = "mL/Hour"
      Case Else
        If txtinitstren.Value Then
          txtdose.Value = Round($rData1["flddose"] / txtinitstren.Value, -2)
        Endif
        lblunit.Text = modPharmLabel.GetDosageFormForLabel($rData1["flditem"], "Inpatient")
    End Select

    FillGridView(txtid.Value)
    If chkdisp.Value = True Then
      btnsave.Enabled = True
    Else
      btnsave.Enabled = False
    Endif
    If modBasic.$TabletModeEnable = "Yes" Then
    Else
      ' txtdose.SetFocus
    Endif

  Endif

End

