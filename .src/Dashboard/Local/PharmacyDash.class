  GridView3.Columns.Count = $Headers.Count
  ResizeGrid(GridView3)

End

Private Sub ResizeGrid(xGridView As WebTable)

  With xGridView
    .Columns[0].Expand = True
    .Columns[1].Width = CStr(75 * $wdFactor) & "px"
    .Columns[2].Hidden = True

    .Columns[0].Text = $Headers[0]
    .Columns[1].Text = $Headers[1]
  End With

End

Public Sub GridView1_Data(Row As Integer, Column As Integer, Data As WebTableData)

  modGridView.GridViewDecoration(Data, Row)
  Data.Text = $GridVar1[Row][$Headers[Column]]

End

Public Sub GridView2_Data(Row As Integer, Column As Integer, Data As WebTableData)

  modGridView.GridViewDecoration(Data, Row)
  Data.Text = $GridVar2[Row][$Headers[Column]]

End

Public Sub GridView3_Data(Row As Integer, Column As Integer, Data As WebTableData)

  modGridView.GridViewDecoration(Data, Row)
  Data.Text = $GridVar3[Row][$Headers[Column]]

End
