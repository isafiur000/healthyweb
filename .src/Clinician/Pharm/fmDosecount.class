Private Sub FillGridView(dosno As Long)

  If $useCardex = True Then
    $rData = modDatabase.$syConn.Exec("select fldid,fldtime,fldid,fldvalue,fldunit,fldid,fldvalue,flduserid from tblnurdosing where fldencounterval=&1 and fldcardex=&2 ORDER BY fldtime DESC", $encid, dosno)
  Else
    $rData = modDatabase.$syConn.Exec("select fldid,fldtime,fldid,fldvalue,fldunit,fldid,fldvalue,flduserid from tblnurdosing where fldencounterval=&1 and flddoseno=&2 ORDER BY fldtime DESC", $encid, dosno)
  Endif
  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView1, $rData, $aMyFields)

  With GridView1
    .Columns[0].Hidden = True
    .Columns[1].Width = CStr(140 * modBasic.$AppWidthRatio) & "px"
    .Columns[2].Width = CStr(275 * modBasic.$AppWidthRatio) & "px"
    .Columns[3].Width = CStr(50 * modBasic.$AppWidthRatio) & "px"
    .Columns[4].Width = CStr(75 * modBasic.$AppWidthRatio) & "px"
    .Columns[5].Width = CStr(25 * modBasic.$AppWidthRatio) & "px"
    .Columns[6].Width = CStr(75 * modBasic.$AppWidthRatio) & "px"
    .Columns[7].Width = CStr(125 * modBasic.$AppWidthRatio) & "px"

    .Columns[1].Text = "DateTime"
    .Columns[2].Text = "Particulars"
    .Columns[3].Text = "QTY"
    .Columns[4].Text = "Unit"
    .Columns[6].Text = "Dose"
    .Columns[7].Text = "Medicator"
  End With

  If $rData.Count Then
    If $useCardex = True Then
      txtcounttoday.Value = modPharmacy.TotalDoseCountCardex(dosno, Now())
      txtdosetoday.Value = modPharmacy.TotalDoseAmountCardex(dosno, Now())
      txtcountsum.Value = modPharmacy.TotalDoseCountCardex(dosno)
      txtdosesum.Value = modPharmacy.TotalDoseAmountCardex(dosno)
    Else
      txtcounttoday.Value = modPharmacy.TotalDoseCount(dosno, Now())
      txtdosetoday.Value = modPharmacy.TotalDoseAmount(dosno, Now())
      txtcountsum.Value = modPharmacy.TotalDoseCount(dosno)
      txtdosesum.Value = modPharmacy.TotalDoseAmount(dosno)
    Endif

  Else
    txtcounttoday.Value = 0
    txtdosetoday.Value = 0
    txtcountsum.Value = 0
    txtdosesum.Value = 0
  Endif

End

Public Sub GridView1_Data(Row As Integer, Column As Integer, Data As WebTableData)

  $rData.MoveTo(Row)
  modGridView.GridViewDecoration(Data, Row)
  If Column = 1 Then
    Data.Text = modReportVar.GetDateTimeReport($rData[$aMyFields[Column]], gb.MediumDate) & Space(1) & modReportVar.GetDateTimeReport($rData[$aMyFields[Column]], gb.ShortTime)
  Else If Column = 2 Then
    Data.Text = txtmedname.Text
  Else If Column = 5 Then
    Data.Html = modString.GetImageForHTMLGrid(modGeneralMain.GetSystemIcon(GetPictureDosing($rData[$aMyFields[Column]])), "15%", "auto")
    Data.Text = ""
  Else If Column = 6 Then
    Data.Text = $rData[$aMyFields[Column]] * txtinitstren.Value
  Else If Column = 7 Then
    Data.Text = modGeneral.GetUserFullName($rData[$aMyFields[Column]])
  Else
    Data.Text = $rData[$aMyFields[Column]]
  Endif

End

Private Function GetPictureDosing(dosid As Long) As String

  Dim res As Result
  Dim xx As String
  Dim xrout As String

  res = modDatabase.$myConn.Exec("select flddoseno,fldfromtime,fldtotime from tblnurdosing where fldid=&1", dosid)
  If res.Available Then
    xrout = modPharmacy.GetRouteFromDosing(res["flddoseno"])
    If xrout = "injection" Or If xrout = "fluid" Or If xrout = "CIV" Or If xrout = "IIV" Then
      If Not res["fldfromtime"] Then
        xx = "icon:/32/play"
      Else If res["fldfromtime"] And If Not res["fldtotime"] Then
        xx = "icon:/32/stop"
      Else If res["fldfromtime"] And If res["fldtotime"] Then
        xx = "icon:/32/lock"
      Endif
    Else
      xx = "icon:/32/lock"
    Endif
  Endif
  Return xx

End

Public Sub btnsave_Click()

  Dim res As Result

  If txtid.Value And If txtdose.Value Then
    If chkdisp.Value = True Then
      modPharmSub.InsertNurDosingIndoor($encid, txtid.Value, txtcardex.Value, txtdose.Value, lblunit.Text, lblmedicine.Text, txtordose.Value, txtorfreq.Text)
      If lblregimen.Tag = "stat" Then
        res = modDatabase.$myConn.Edit("tblpatdosing", "fldid=&1", txtid.Value)
        res["fldcurval"] = "Completed"
        res.Update
      Endif
    Else

    Endif

    FillGridView(txtid.Value)
    btnsave.Enabled = False
    txtdose.Value = 0

  Endif

End

Public Sub btnexpo_Click()

  If lblmedicine.Text Then
    modCHTMLReport.ExportGridToHTML(GridView1, lblmedicine.Text, "Dosing Report",, $encid)
  Endif

End

Public Sub btndoseedit_Click()

  Dim res As Result
  Dim xval As Float

  If GridView1.Selection.Count Then
    $rData.MoveTo(GridView1.Selection[0])
    xval = InputValue(txtmedname.Text, ("Change Value"), $rData["fldvalue"])
    If xval Then
      res = modDatabase.$myConn.Edit("tblnurdosing", "fldid=&1", $rData["fldid"])
      If modGeneral.AllowClinicalEdit(res["flduserid"]) = True Then
        res["fldvalue"] = xval
        res["xyz"] = False
        res["flduserid"] = modBasic.$lbluser
        res.Update
        FillGridView(txtid.Value)
      Else
        Message.Warning("Authorization with " & res["flduserid"], ("OK"))
      Endif
    Endif
  Endif

End

Public Sub btndosestop_Click()

  Dim res As Result

  If GridView1.Selection.Count Then
    $rData.MoveTo(GridView1.Selection[0])
    res = modDatabase.$myConn.Edit("tblnurdosing", "fldid=&1", $rData["fldid"])
    If GetPictureDosing($rData["fldid"]) = "icon:/32/play" Then
      res["fldfromtime"] = Now()
      res["xyz"] = False
      res.Update
      FillGridView(txtid.Value)
    Else If GetPictureDosing($rData["fldid"]) = "icon:/32/stop" Then
      res["fldtotime"] = Now()
      res["xyz"] = False
      res.Update
      FillGridView(txtid.Value)
    Endif
  Endif

End

Public Sub btninjection_Click()

  Dim res As Result
  Dim hForm As FmInjection

  If btninjection.Tag Then
    res = modDatabase.$medConn.Exec("select fldlabel from tbllabel where flddrug=&1 and fldsubroute=&2", modMedConstant.GetDrugFromStockID(lblmedicine.Text), btninjection.Tag)
    If res.Available Then
      res.MoveFirst
      hForm = New FmInjection(btninjection.Tag, res["fldlabel"])
      hForm.ShowModal
    Endif
  Endif

End

''================ Local Transfer ==================
Private Sub SaveOwnDispensing(sID As Long)

  Dim sql1 As String
  Dim res1 As Result
  Dim hForm As CPharmOwn

  sql1 = "select fldid,fldtime,fldroute,flditem,flddose,fldfreq,flddays,fldqtydisp,fldlabel,flditemtype,fldfixname,fldfixrate,fldtaxper,flddiscper,fldbillingmode,flddisctype,fldacledger,fldbilltype,fldcashincredit from tblpatdosing where fldid=&1 and fldencounterval=&2"                                                   ''
  res1 = modDatabase.$myConn.Exec(sql1, sID, $encid)
  If res1.Available = True Then
    hForm = New CPharmOwn($encid, $sBillMode, res1)
    If $sClaimState = "Consultation" Or If $sClaimState = "Patient Ward" Then
      GetHImedicineCappingVar()
    Endif
    hForm.SetCappingLimit($HiCappingVar)
    hForm.DispenseItem("Continue")
  Endif

End

Private Sub SaveCardexDispensing(sCardex As Long, xHash As String)

  Dim sql1 As String
  Dim res1 As Result
  Dim hForm As CPharmOwn
  Dim xIndex As Long

  sql1 = "select fldid,fldtime,fldroute,flditem,flddose,fldfreq,flddays,fldqtydisp,fldlabel,flditemtype,fldfixname,fldfixrate,fldtaxper,flddiscper,fldbillingmode,flddisctype,fldacledger,fldbilltype,fldcashincredit from tblpatdosing where flditemno=&1 and fldencounterval=&2 and fldextrarow=&3 and fldsave_order=&4"                                                   ''
  res1 = modDatabase.$myConn.Exec(sql1, sCardex, $encid, xHash, False)
  If res1.Available = True Then
    If res1.Count = 1 Then
      xIndex = res1["fldid"]
      hForm = New CPharmOwn($encid, $sBillMode, res1)
      If $sClaimState = "Consultation" Or If $sClaimState = "Patient Ward" Then
        GetHImedicineCappingVar()
      Endif
      hForm.SetCappingLimit($HiCappingVar)
      hForm.DispenseItem("Continue")
      If hForm.GetOutcome() = False Then
        modDatabase.$myConn.Delete("tblpatdosing", "fldid=&1 and fldencounterval=&2 and fldsave_order=&3", xIndex, $encid, False)
      Endif
    Endif
  Endif

End

Public Sub btnreceive_Click()

  Dim xhash As String

  If chkuselocal.Value = True Then
    If txttransqty.Value Then
      If $useCardex = True Then
        xhash = modString.GetNowString()
        CreateMedicineOrder(txtcardex.Value, xhash)
        SaveCardexDispensing(txtcardex.Value, xhash)
      Else
        SaveOwnDispensing(txtid.Value)
      Endif
      chkuselocal.Value = False
      FillMedicineList()
    Endif
  Endif

End

Private Function CreateMedicineOrder(sCardex As Long, xHash As String) As Long

  Dim res As Result
  Dim xflvool As Float
  Dim xflrate As Float

  Dim xtax As Float
  Dim xdisc As Float
  Dim itemtype As String
  Dim xfixrate As Float
  Dim xfixname As String
  Dim itemmode As String
  Dim CPharmFix As CFixRatePharmacy
  Dim xgo As Boolean
  Dim xallow As Boolean

  res = modDatabase.$myConn.Exec("select fldid,fldroute,flditem,flddose,fldfreq,flddays,fldqtyorder,fldprescriber,fldregno,flddirection,fldadminsite,fldmixing,fldstarttime,fldendtime,fldmixvolume,fldmixrate from tblinpatdosing where fldid=&1 and fldencounterval=&2 and fldcurval=&3 and fldsave=&4", sCardex, $encid, "Continue", False)                 ''
  If res.Available Then
    If res["fldmixvolume"] Then
      xflvool = res["fldmixvolume"]
    Else
      xflvool = 0
    Endif
    If res["fldmixrate"] Then
      xflrate = res["fldmixrate"]
    Else
      xflrate = 0
    Endif
    xallow = False
    If res["fldendtime"] >= modDate.StartSqlDate(Now()) Then
      xallow = True
    Else If res["flddays"] = 0 Then
      xallow = True
    Endif

    If xallow = True Then

      itemtype = modNonMedical.GetBillItemCategoryFromCombo(res["fldroute"])
      xgo = False
      If modBasic.$BillPharmFixedModes.Exist($sBillMode) = True Then
        CPharmFix = New CFixRatePharmacy(itemtype, res["flditem"], $sBillMode)
        xfixrate = CPharmFix.GetFixRate()
        xfixname = CPharmFix.GetFixItem()
        If xfixname Then
          xgo = True
        Else
          xgo = False
        Endif
      Else
        xgo = True
      Endif

      If xgo = True Then
        itemmode = $sBillMode
        xtax = modNonMedical.ShowTaxValues(itemtype, res["flditem"])
        xdisc = modNonMedical.DiscPercentForCategoryValue($encid, cmbdisctype.Text, itemtype, res["flditem"], itemmode)
        modPharmSub.InsertDosingMedicine($encid, $xBillType, $sBillMode, cmbdisctype.Text, $LedgerAC, res["fldroute"], res["flditem"], res["flddose"], res["fldfreq"], res["flddays"], txttransqty.Value, $status, res["fldprescriber"], res["fldregno"], Now(), xtax, xdisc, xfixname, xfixrate, "Request", "IPD", res["flddirection"], 0, res["fldid"], "Continue", res["fldadminsite"], res["fldmixing"], xflrate, xflvool, xHash)              ''
      Endif

    Endif
  Endif

End
