' Gambas class file

Export

Private $wdFactor As Float

Private $Headers As String[]
Private xGridVar1 As Variant[]
Private xGridVar2 As Variant[]
Private xGridVar3 As Variant[]

Private $GridVar1 As Variant[]
Private $GridVar2 As Variant[]
Private $GridVar3 As Variant[]

Private $grdInit1 As Integer
Private $grdInit2 As Integer
Private $grdInit3 As Integer
Private $grdTot1 As Integer
Private $grdTot2 As Integer
Private $grdTot3 As Integer

Static Public Sub _init()

  Env["GB_WEB_GUI_DEBUG"] = "1"
  modHelpVariable.GetSessionParam()

End

Public Sub _new()

  Dim xwid As String
  Dim xfont As String

  Me.AddHeader("<meta name='viewport' content='width=device-width, initial-scale=1'>")
  Me.AddHeader("<link rel=\"stylesheet\" href=\"" & modPrint.GetHTTPReferer() & "://" & modHelpVariable.$HostPath & "/css/" & Application.Name & ".css" & "\">")
  ' Me.AddJavascriptFile("js/jquery.min.js")
  Me.AddJavascriptFile("js/webcontrols.js")
  WebForm.Debug = True

  modHelpVariable.MakeWorkingDir()
  modHelpVariable.CreateWorkingDir()
  modHelpVariable.SetAppConfigFile()

  ' cmbleftrow.List = ["Medicines", "Surgicals"]
  cmbleftrow.Text = "Medicines"
  ' cmbmidrow.List = ["Medicines", "Surgicals"]
  cmbmidrow.Text = "Medicines"
  cmbrightrow.List = ["Medicines", "Surgicals"]
  cmbrightrow.Text = "Surgicals"
  cmbdepart.List = modGeneralMain.GetWebDepartList()
  If cmbdepart.List.Count Then
    cmbdepart.Text = cmbdepart.List[0]
  Endif

  xfont = modSettings.ShowSettingFromFIle("Application/ApplicationFont")
  If xfont Then
    Me.Font = xfont
  Endif

  WebImage1.Image = modPrint.GetFixedWebURL(modHelpVariable.$appetcFolder &/ "header-logo.png")
  WebImage2.Image = modPrint.GetFixedWebURL(modHelpVariable.$appetcFolder &/ "header.jpg")
  WebHtml2.Html = "<small>Developed By: D Code Technology Pvt Ltd, Kathmandu</small>"

  xwid = modSettings.ShowSettingFromFIle("PatientDashBoard/WidthFactor")
  If xwid Then
    $wdFactor = CFloat(xwid)
  Else
    $wdFactor = 1
  Endif

End

Public Sub btnfullscreen_Click()

  If btnfullscreen.Image = "icon:/small/zoom-normal" Then
    btnfullscreen.Image = "icon:/small/zoom-fit"
    Me.Exec("openFullscreen()")

  Else If btnfullscreen.Image = "icon:/small/zoom-fit" Then
    btnfullscreen.Image = "icon:/small/zoom-normal"
    Me.Exec("closeFullscreen()")

  Endif

End

Public Sub WebForm_Close()

  Session.Abandon()
  Try modDatabase.$syConn.Close()
  Try modDatabase.$myConn.Close()
  modExternal.DeleteFolderRecursive("/tmp" &/ modHelpVariable.AppName &/ "docs" &/ modHelpVariable.$SessionCode)
  modExternal.DeleteFolderRecursive(modHelpVariable.AppCacheDir)

End

Public Sub btnrefresh_Click()

  If Not modDatabase.$syConn Or If Not modDatabase.$syConn.Opened Then
    modHelpVariable.ConnectionDashboard()
    modGeneralMain.EnableCollectionCache()
    modTableCache.InitializeTableCache()
  Endif
  If modDatabase.$syConn.Opened = True Then
    If cmbdepart.Text Then
      FillBedGrid()
      If chkrefresh.Value = True Then
        Timer1.Enabled = True
      Else
        Timer1.Enabled = False
      Endif
    Endif
    Try modDatabase.$syConn.Close()
  Endif

End

Public Sub WebTimer1_Timer()

  txttimer.Text = Format(Time(Now()), "hh:nn:ss")

End

Public Sub Timer1_Timer()

  If Minute(Now()) = 10 Then
    If cmbdepart.Text Then
      FillBedGrid()
    Endif

  Else

    Select Second(Now())
      Case 9, 19, 29, 39, 49, 59
        If xGridVar1.Count Then
          If ($grdInit1 + 1) >= $grdTot1 Then
            $grdInit1 = 0
          Endif
          GetGridViewOne(xGridVar1, $grdInit1, $grdInit1 + spncolumn1.Value)
          $grdInit1 = $grdInit1 + spncolumn1.Value
        Endif

        If xGridVar2.Count Then
          If ($grdInit2 + 1) >= $grdTot2 Then
            $grdInit2 = 0
          Endif
          GetGridViewTwo(xGridVar2, $grdInit2, $grdInit2 + spncolumn2.Value)
          $grdInit2 = $grdInit2 + spncolumn2.Value
        Endif

        If xGridVar3.Count Then
          If ($grdInit3 + 1) >= $grdTot3 Then
            $grdInit3 = 0
          Endif
          GetGridViewThree(xGridVar3, $grdInit3, $grdInit3 + spncolumn3.Value)
          $grdInit3 = $grdInit3 + spncolumn3.Value
        Endif
    End Select

  Endif

End

Public Function GetSelectedResult(sCategory As String, sRoute As String[]) As Result

  Dim sql As String
  Dim res As Result
  Dim xstr As String

  Dim strItem As String[]
  Dim i As Integer

  strItem = sRoute.Copy()
  For i = 0 To strItem.Count - 1
    strItem[i] = "'" & strItem[i] & "'"
  Next

  If sCategory = "Medicines" Then
    xstr = " and fldstockid in(select fldbrandid from tblmedbrand where flddrug in(select flddrug from tbldrug where fldroute in(" & strItem.Join(",") & ")" & "))"
  Else If sCategory = "Surgicals" Then
    xstr = " and fldstockid in(select fldbrandid from tblsurgbrand where fldsurgid in(select fldsurgid from tblsurgicals where fldsurgcateg in(" & strItem.Join(",") & ")" & "))"
  Endif
  sql = "select fldstockid,fldsellpr from tblentry where fldcomp=&1 and fldcategory=&2 and fldstatus=&3" & xstr & "ORDER BY fldstockid"
  res = modDatabase.$syConn.Exec(sql, cmbdepart.Text, sCategory, 1, sRoute)

  Return res

End

Private Sub FillBedGrid()

  Dim res1 As Result
  Dim res2 As Result
  Dim res3 As Result
  Dim i As Integer
  Dim j As Integer
  Dim k As Integer

  Dim sColl As Collection

  $Headers = ["Particular", "Price", "Index"]
  If cmbleftrow.Text = "Medicines" And If cmbmidrow.Text = "Medicines" And If cmbrightrow.Text = "Medicines" Then
    res1 = GetSelectedResult("Medicines", ["oral", "liquid"])
    res2 = GetSelectedResult("Medicines", ["injection", "fluid"])
    res3 = GetSelectedResult("Medicines", ["resp", "topical", "eye/ear", "anal/vaginal"])
  Else If cmbleftrow.Text = "Medicines" And If cmbmidrow.Text = "Medicines" And If cmbrightrow.Text = "Surgicals" Then
    res1 = GetSelectedResult("Medicines", ["oral", "liquid"])
    res2 = GetSelectedResult("Medicines", ["injection", "fluid"])
    res3 = GetSelectedResult("Surgicals", ["msurg"])
  Endif

  i = 0
  xGridVar1 = New Variant[]
  If res1.Available Then
    $grdTot1 = res1.Count
    $grdInit1 = 0
    For Each res1
      sColl = New Collection
      sColl.Add(res1["fldstockid"], $Headers[0])
      sColl.Add(res1["fldsellpr"], $Headers[1])
      sColl.Add(i, $Headers[2])
      xGridVar1.Add(sColl)
      i = i + 1
    Next
  Endif

  j = 0
  xGridVar2 = New Variant[]
  If res2.Available Then
    $grdTot2 = res2.Count
    $grdInit2 = 0
    For Each res2
      sColl = New Collection
      sColl.Add(res2["fldstockid"], $Headers[0])
      sColl.Add(res2["fldsellpr"], $Headers[1])
      sColl.Add(j, $Headers[2])
      xGridVar2.Add(sColl)
      j = j + 1
    Next
  Endif

  k = 0
  xGridVar3 = New Variant[]
  If res3.Available Then
    $grdTot3 = res3.Count
    $grdInit3 = 0
    For Each res3
      sColl = New Collection
      sColl.Add(res3["fldstockid"], $Headers[0])
      sColl.Add(res3["fldsellpr"], $Headers[1])
      sColl.Add(k, $Headers[2])
      xGridVar3.Add(sColl)
      k = k + 1
    Next
  Endif

End

Private Sub GetGridViewOne(xGridVar As Variant[], xStart As Integer, sEnd As Integer)

  Dim xVarLst As Variant[]
  Dim xVar As Variant
  Dim sColl As Collection

  xVarLst = New Variant[]
  For Each xVar In xGridVar
    sColl = xVar
    If sColl["Index"] <= xGridVar.Count - 1
      If sColl["Index"] >= xStart And If sColl["Index"] < sEnd Then
        xVarLst.Add(sColl)
      Endif
    Endif
  Next

  $GridVar1 = xVarLst
  GridView1.Count = $GridVar1.Count
  GridView1.Columns.Count = $Headers.Count
  ResizeGrid(GridView1)

End

