Private Sub ShowMedicines()

  Dim res As Result
  Dim sql As String
  Dim sql1 As String

  Dim xfir As Date
  Dim dtList As Date[]
  Dim Column As Integer
  Dim sColl As Collection
  Dim xcount As Integer
  Dim xVar As Variant[]

  If chkall.Value = False Then
    If rbroutine.Value = True Then
      sql = "select fldid,fldstarttime,fldroute,flditem,flddose,fldfreq,flddays,fldcurval,flddirection from tblinpatdosing where fldencounterval=&1 and fldstarttime<=&2 and fldendtime>=&3 and fldroute<>&4 and flddays>&5 and fldcurval=&6 and fldfreq<>&7 and fldfreq<>&8"
      sql1 = "select fldid,fldstarttime,fldroute,flditem,flddose,fldfreq,flddays,fldcurval,flddirection from tblinpatdosing where fldencounterval=&1 and fldroute<>&4 and flddays=&5 and fldcurval=&6 and fldfreq<>&7 and fldfreq<>&8"
    Else If rbprn.Value = True Then
      sql = "select fldid,fldstarttime,fldroute,flditem,flddose,fldfreq,flddays,fldcurval,flddirection from tblinpatdosing where fldencounterval=&1 and fldstarttime<=&2 and fldendtime>=&3 and fldroute<>&4 and flddays>&5 and fldcurval=&6 and (fldfreq=&7 or fldfreq=&8)"
      sql1 = "select fldid,fldstarttime,fldroute,flditem,flddose,fldfreq,flddays,fldcurval,flddirection from tblinpatdosing where fldencounterval=&1 and fldroute<>&4 and flddays=&5 and fldcurval=&6 and (fldfreq=&7 or fldfreq=&8)"
    Endif
    res = modDatabase.$myConn.Exec(sql & " UNION " & sql1 & " ORDER BY fldstarttime DESC", $encid, Now(), DateAdd(Now(), gb.Hour, -3), "fluid", 0, "Continue", "stat", "PRN")

  Else If chkall.Value = True Then
    If rbroutine.Value = True Then
      sql = "select fldid,fldstarttime,fldroute,flditem,flddose,fldfreq,flddays,fldcurval,flddirection from tblinpatdosing where fldencounterval=&1 and fldroute<>&2 and fldfreq<>&3 and fldfreq<>&4 ORDER BY fldstarttime DESC"
    Else If rbprn.Value = True Then
      sql = "select fldid,fldstarttime,fldroute,flditem,flddose,fldfreq,flddays,fldcurval,flddirection from tblinpatdosing where fldencounterval=&1 and fldroute<>&2 and (fldfreq=&3 or fldfreq=&4) ORDER BY fldstarttime DESC"
    Endif
    res = modDatabase.$myConn.Exec(sql, $encid, "fluid", "stat", "PRN")

  Endif
  $rDatax = res

  dtList = New Date[]
  If res.Available Then
    res.MoveFirst
    xfir = modDate.StartSqlDate(res["fldstarttime"])
    For Each res
      If xfir > res["fldstarttime"] Then
        xfir = res["fldstarttime"]
      Endif
    Next
    dtList = modDate.GetDateArrayBetween(xfir, Now())
  Endif
  dtList.Sort(gb.Descent)

  xVar = New Variant[]
  GridView2.Count = res.Count
  GridView2.Columns.Count = 6 + dtList.Count
  For Each res
    sColl = New Collection

    sColl.Add(res["fldid"], CStr(0))
    sColl.Add(modReportVar.GetDateTimeReport(res["fldstarttime"], gb.GeneralDate), CStr(1))
    sColl.Add(res["fldroute"], CStr(2))
    sColl.Add(res["flditem"], CStr(3))
    sColl.Add(modMedConstant.GetMedicineRegimenInFormat(res["fldroute"], res["flditem"], res["flddose"], res["fldfreq"], res["flddays"]), CStr(4))

    For Column = 0 To dtList.Count - 1
      xcount = 0
      xcount = modPharmacy.TotalDoseCountCardex(res["fldid"], dtList[Column])
      If xcount Then
        sColl.Add(xcount, CStr(5 + Column))
      Else
        sColl.Add("", CStr(5 + Column))
      Endif
    Next
    sColl.Add(res["flddirection"], CStr(5 + dtList.Count))
    xVar.Add(sColl)
  Next

  $gridVar = xVar
  With GridView2
    .Columns[0].Hidden = False
    .Columns[1].Width = CStr(150 * modBasic.$AppWidthRatio) & "px"
    .Columns[2].Width = CStr(75 * modBasic.$AppWidthRatio) & "px"
    .Columns[3].Width = CStr(375 * modBasic.$AppWidthRatio) & "px"
    .Columns[4].Width = CStr(150 * modBasic.$AppWidthRatio) & "px"

    .Columns[1].Text = "StartDate"
    .Columns[2].Text = "Route"
    .Columns[3].Text = "Medicine"
    .Columns[4].Text = "Regimen"

    For Column = 0 To dtList.Count - 1
      .Columns[5 + Column].Width = CStr(50 * modBasic.$AppWidthRatio) & "px"
      .Columns[5 + Column].Text = modReportVar.GetDateTimeReport(dtList[Column], gb.ShortDate)
    Next
    .Columns[5 + dtList.Count].Width = CStr(200 * modBasic.$AppWidthRatio) & "px"
    .Columns[5 + dtList.Count].Text = "Direction"

  End With

End

Public Sub GridView2_Data(Row As Integer, Column As Integer, Data As WebTableData)

  modGridView.GridViewDecoration(Data, Row)
  Data.Text = $gridVar[Row][CStr(Column)]

End

''========================== Admixtures ================================
Private Sub ShowAdmixtures()

  Dim sFieldLst As String[]
  Dim sql As String
  Dim rsx As Result
  Dim res As Result

  Dim pic2 As String
  Dim pic3 As String

  Dim Column As Integer
  Dim fld As ResultField

  pic2 = "icons/coll4.png"
  pic3 = "icons/unchecked.png"
  sFieldLst = ["flditem", "fldroute", "CONCAT(flditem, '|', flddose)", "fldfreq", "flddays", "fldcurval", "fldqtyorder", "fldid", "flduserid", "fldstarttime", "fldid", "flddirection", "fldadminsite", "flduserid", "fldmixvolume", "fldmixrate", "flddose"]

  If cmbstatus.Text = "%" Then
    rsx = modDatabase.$myConn.Exec("select distinct(fldmixing) as fldmixing from tblinpatdosing where fldencounterval=&1 and fldmixing LIKE &2 ORDER BY fldstarttime DESC", $encid, "ADMIXTURE:" & "%")
  Else
    rsx = modDatabase.$myConn.Exec("select distinct(fldmixing) as fldmixing from tblinpatdosing where fldencounterval=&1 and fldmixing LIKE &2 and fldcurval=&3 and fldsave=&4 ORDER BY fldstarttime DESC", $encid, "ADMIXTURE:" & "%", cmbstatus.Text, False)
  Endif
  If rsx.Available Then
    ColumnView1.Visible = True
    ColumnView1.Clear
    ColumnView1.Columns.Count = sFieldLst.Count
    With ColumnView1
      .Columns[0].Text = "Medicine"
      .Columns[1].Text = "Route"
      .Columns[2].Text = "Dose"
      .Columns[3].Text = "Freq"
      .Columns[4].Text = "Days"
      .Columns[5].Text = "Status"
      .Columns[6].Text = "QTY"
      .Columns[8].Text = "Doctor"
      .Columns[9].Text = "Start"
      .Columns[10].Text = "N"
      .Columns[11].Text = "Direction"
      .Columns[12].Text = "Admin"
      .Columns[14].Text = "Vol(mL)"
      .Columns[15].Text = "mL/Hour"
    End With

    For Each rsx
      ColumnView1.Add(rsx["fldmixing"], rsx["fldmixing"], pic2)

      If cmbstatus.Text = "%" Then
        sql = "select " & sFieldLst.Join(",") & " from tblinpatdosing where fldencounterval=&1 and fldmixing=&2"
        res = modDatabase.$myConn.Exec(sql, $encid, rsx["fldmixing"])
      Else
        sql = "select " & sFieldLst.Join(",") & " from tblinpatdosing where fldencounterval=&1 and fldcurval=&2 and fldsave=&3 and fldmixing=&4"
        res = modDatabase.$myConn.Exec(sql, $encid, cmbstatus.Text, False, rsx["fldmixing"])
      Endif
      If res.Available Then
        For Each res
          ColumnView1.Add(rsx["fldmixing"] & "@" & CStr(res["fldid"]), res["fldid"], pic3, rsx["fldmixing"])
          Column = 0
          For Each fld In res.Fields
            If Column = 2 Then
              ColumnView1[rsx["fldmixing"] & "@" & CStr(res["fldid"])][Column] = GetMedicineDose(res[fld.Name])
            Else If Column = 8 Then
              ColumnView1[rsx["fldmixing"] & "@" & CStr(res["fldid"])][Column] = modGeneral.GetUserFullName(res[fld.Name])
            Else If Column = 9 Then
              ColumnView1[rsx["fldmixing"] & "@" & CStr(res["fldid"])][Column] = modReportVar.GetDateTimeReport(res[fld.Name], gb.GeneralDate)
            Else If Column = 10 Then
              ColumnView1[rsx["fldmixing"] & "@" & CStr(res["fldid"])][Column] = "" 'res[fld.Name]
            Else
              ColumnView1[rsx["fldmixing"] & "@" & CStr(res["fldid"])][Column] = res[fld.Name]
            Endif
            Column = Column + 1
          Next
        Next
      Endif

    Next

    With ColumnView1
      .Columns[0].Width = CStr(350 * modBasic.$AppWidthRatio) & "px"
      .Columns[1].Width = CStr(75 * modBasic.$AppWidthRatio) & "px"
      .Columns[2].Width = CStr(100 * modBasic.$AppWidthRatio) & "px"
      .Columns[3].Width = CStr(100 * modBasic.$AppWidthRatio) & "px"
      .Columns[4].Width = CStr(50 * modBasic.$AppWidthRatio) & "px"
      .Columns[5].Width = CStr(100 * modBasic.$AppWidthRatio) & "px"
      .Columns[6].Width = CStr(50 * modBasic.$AppWidthRatio) & "px"
      .Columns[7].Hidden = True
      .Columns[8].Width = CStr(125 * modBasic.$AppWidthRatio) & "px"
      .Columns[9].Width = CStr(150 * modBasic.$AppWidthRatio) & "px"
      .Columns[10].Width = CStr(50 * modBasic.$AppWidthRatio) & "px"
      .Columns[11].Width = CStr(250 * modBasic.$AppWidthRatio) & "px"
      .Columns[12].Width = CStr(150 * modBasic.$AppWidthRatio) & "px"
      .Columns[13].Hidden = True
      .Columns[14].Width = CStr(75 * modBasic.$AppWidthRatio) & "px"
      .Columns[15].Width = CStr(75 * modBasic.$AppWidthRatio) & "px"
      .Columns[16].Hidden = True
    End With

  Else
    ColumnView1.Visible = False
  Endif

End

Public Sub ColumnView1_Select()

  If ColumnView1.Current.Image = "icons/unchecked.png" Then
    ColumnView1.Current.Image = "icons/checked.png"
  Else If ColumnView1.Current.Image = "icons/checked.png" Then
    ColumnView1.Current.Image = "icons/unchecked.png"
  Endif

End

Public Sub mnueditstate_Click()

  Dim yval As String
  Dim res As Result

  yval = InputCombo(ColumnView1[ColumnView1.Current.Key][0], ("Alter Status"), $StateList, ColumnView1[ColumnView1.Current.Key][5], True)
  If yval Then
    res = modDatabase.$myConn.Edit("tblinpatdosing", "fldid=&1 and fldencounterval=&2", CLong(ColumnView1[ColumnView1.Current.Key][7]), $encid)
    res["fldcurval"] = yval
    res["xyz"] = False
    res.Update
    ShowAdmixtures()
  Endif

End

Public Sub mnueditdose_Click()

  Dim xval As Float
  Dim res As Result

  If modGeneral.AllowClinicalEdit(ColumnView1[ColumnView1.Current.Key][13]) = True Then
    If ColumnView1[ColumnView1.Current.Key][16] Then
      xval = InputValue(ColumnView1[ColumnView1.Current.Key][0], ("Alter Unit Dose"), ColumnView1[ColumnView1.Current.Key][16])
    Else
      xval = InputValue(ColumnView1[ColumnView1.Current.Key][0], ("Alter Unit Dose"), 0)
    Endif
    If xval Then
      res = modDatabase.$myConn.Edit("tblinpatdosing", "fldid=&1 and fldencounterval=&2", CLong(ColumnView1[ColumnView1.Current.Key][7]), $encid)
      res["flddose"] = xval
      res["xyz"] = False
      res.Update
      ShowAdmixtures()
    Endif
  Endif

End

Public Sub mnueditdays_Click()

  Dim xval As Float
  Dim res As Result

  If modGeneral.AllowClinicalEdit(ColumnView1[ColumnView1.Current.Key][13]) = True Then
    xval = InputValue(ColumnView1[ColumnView1.Current.Key][0], ("Alter Duration"), ColumnView1[ColumnView1.Current.Key][4])
    If xval >= 0 Then
      res = modDatabase.$myConn.Edit("tblinpatdosing", "fldid=&1 and fldencounterval=&2", CLong(ColumnView1[ColumnView1.Current.Key][7]), $encid)
      res["flddays"] = xval
      If xval Then
        res["fldendtime"] = DateAdd(res["fldstarttime"], gb.Hour, CInt(xval * 24))
      Endif
      res["xyz"] = False
      res.Update
      ShowAdmixtures()
    Endif
  Endif

End

Public Sub mnueditdirection_Click()

  Dim yval As String
  Dim res As Result

  If modGeneral.AllowClinicalEdit(ColumnView1[ColumnView1.Current.Key][13]) = True Then
    yval = GetTextArea(ColumnView1[ColumnView1.Current.Key][0], ColumnView1[ColumnView1.Current.Key][11])
    If yval Then
      res = modDatabase.$myConn.Edit("tblinpatdosing", "fldid=&1 and fldencounterval=&2", CLong(ColumnView1[ColumnView1.Current.Key][7]), $encid)
      res["flddirection"] = Trim(yval)
      res["xyz"] = False
      res.Update
      ShowAdmixtures()
    Endif
  Endif

End
