  Dim xVarLst As Variant[]
  Dim xVar As Variant
  Dim sColl As Collection

  xVarLst = New Variant[]
  For Each xVar In xGridVar
    sColl = xVar
    If sColl["Index"] <= xGridVar.Count - 1
      If sColl["Index"] >= xStart And If sColl["Index"] < sEnd Then
        xVarLst.Add(sColl)
      Endif
    Endif
  Next

  $GridVar2 = xVarLst
