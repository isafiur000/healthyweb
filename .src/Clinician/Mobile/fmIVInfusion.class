' Gambas class file

Private $encid As String

Private $rFludRes As Result
Private $aFludFields As String[]
Private $rRateRes As Result
Private $aRateFields As String[]

Public Sub _new(encid As String, sClass As String)

  $encid = encid
  WebContainer6.Class = sClass

  ShowMedFluids()

End

Public Sub chkalldate_Click()

  ShowMedFluids()

End

Private Sub ShowMedFluids()

  Dim sql As String
  Dim xrouLst As String[] = ["fluid", "CIV", "CIn(Epid)", "CIn(Block)"]
  Dim j As Integer

  For j = 0 To xrouLst.Count - 1
    xrouLst[j] = "'" & xrouLst[j] & "'"
  Next

  If chkalldate.Value = True Then
    sql = "select fldid,fldid,flditem,flddose,fldfreq,flddays,fldstarttime,fldcurval,fldstarttime,fldstatus,fldendtime,flddirection,fldadminsite,fldmixing,fldroute from tblpatdosing where fldencounterval=&1 and fldsave_order=&2 and fldroute IN(" & xrouLst.Join(",") & ") and fldcurval=&3 and flddose>&4 ORDER BY fldstarttime DESC"
    $rFludRes = modDatabase.$myConn.Exec(sql, $encid, True, "Continue", 0)
  Else
    sql = "select fldid,fldid,flditem,flddose,fldfreq,flddays,fldstarttime,fldcurval,fldstarttime,fldstatus,fldendtime,flddirection,fldadminsite,fldmixing,fldroute from tblpatdosing where fldencounterval=&1 and fldsave_order=&2 and fldroute IN(" & xrouLst.Join(",") & ") and fldcurval=&3 and flddose>&4 and fldstarttime<=&5 and fldendtime>=&6 ORDER BY fldstarttime DESC"
    $rFludRes = modDatabase.$myConn.Exec(sql, $encid, True, "Continue", 0, modDate.EndSqlDate(Now()), modDate.StartSqlDate(Now()))
  Endif
  $aFludFields = New String[]
  modGridView.ReadSmallData(grdfluid, $rFludRes, $aFludFields)

  With grdfluid
    .Columns[0].Hidden = True
    .Columns[1].Width = CStr(25 * modBasic.$AppWidthRatio) & "px"
    .Columns[2].Width = CStr(350 * modBasic.$AppWidthRatio) & "px"
    .Columns[3].Width = CStr(50 * modBasic.$AppWidthRatio) & "px"
    .Columns[4].Width = CStr(100 * modBasic.$AppWidthRatio) & "px"
    .Columns[5].Hidden = True
    .Columns[6].Width = CStr(150 * modBasic.$AppWidthRatio) & "px"
    .Columns[7].Width = CStr(100 * modBasic.$AppWidthRatio) & "px"
    .Columns[8].Hidden = True  ''start time
    .Columns[9].Hidden = True
    .Columns[10].Hidden = True  ''close time
    .Columns[11].Hidden = True
    .Columns[12].Hidden = True
    .Columns[13].Hidden = True
    .Columns[14].Hidden = True

    .Columns[2].Text = "Medicine"
    .Columns[3].Text = "Dose"
    .Columns[4].Text = "Freq"
    .Columns[6].Text = "Date"
    .Columns[7].Text = "Status"
  End With

End

Public Sub grdfluid_Data(Row As Integer, Column As Integer, Data As WebTableData)

  $rFludRes.MoveTo(Row)
  modGridView.GridViewDecoration(Data, Row)
  If Column = 6 Then
    Data.Text = modReportVar.GetDateTimeReport($rFludRes[$aFludFields[Column]], gb.GeneralDate)
  Else If Column = 1 Then
    Data.Html = modString.GetImageForHTMLGrid(modGeneralMain.GetSystemIcon(GetFluidAdminStatusCode($rFludRes[$aFludFields[Column]])), "15px", "15px")
    Data.Text = ""
  Else
    Data.Text = $rFludRes[$aFludFields[Column]]
  Endif

End

Public Sub btndirection_Click()

  If grdfluid.Selection.Count Then
    $rFludRes.MoveTo(grdfluid.Selection[0])
    lblduration.Text = $rFludRes["flddirection"]
  Endif

End

Public Sub btnfluid_Click()

  If grdfluid.Selection.Count Then
    $rFludRes.MoveTo(grdfluid.Selection[0])
    lblduration.Text = $rFludRes["fldmixing"]
  Endif

End

Public Sub btnprotocol_Click()

  Dim res As Result
  Dim hForm As FmInjection

  If grdfluid.Selection.Count Then
    $rFludRes.MoveTo(grdfluid.Selection[0])
    res = modDatabase.$medConn.Exec("select fldlabel from tbllabel where flddrug=&1 and fldsubroute=&2", modMedConstant.GetDrugFromStockID($rFludRes["flditem"]), $rFludRes["fldroute"])
    If res.Available Then
      res.MoveFirst
      hForm = New FmInjection($rFludRes["fldroute"], res["fldlabel"])
      hForm.ShowModal
    Endif
  Endif

End

Private Function GetDateTimeLabel(dt1 As Date, dt2 As Date) As String

  Dim xx As String

  If dt2 Then
    If modDate.StartSqlDate(dt1) = modDate.StartSqlDate(dt2) Then
      xx = modReportVar.GetDateTimeReport(dt1, gb.GeneralDate) & " TO " & modReportVar.GetDateTimeReport(dt2, gb.MediumTime)
    Else
      xx = modReportVar.GetDateTimeReport(dt1, gb.GeneralDate) & " TO " & modReportVar.GetDateTimeReport(dt2, gb.GeneralDate)
    Endif
  Else
    xx = modReportVar.GetDateTimeReport(dt1, gb.GeneralDate)
  Endif
  Return xx

End

Public Sub btntime_Click()

  If grdfluid.Selection.Count Then
    $rFludRes.MoveTo(grdfluid.Selection[0])
    lblduration.Text = GetDateTimeLabel($rFludRes["fldstarttime"], $rFludRes["fldendtime"])
  Endif

End

Public Sub btnfluidstatus_Click()

  Dim xx As String[] = ["Continue", "Discontinue", "On Hold", "Cancelled"]
  Dim res As Result
  Dim xval As String

  If grdfluid.Selection.Count Then
    $rFludRes.MoveTo(grdfluid.Selection[0])
    xval = InputCombo($rFludRes["flditem"], ("Select Current Status"), xx, $rFludRes["fldcurval"], True)
    If xval Then
      res = modDatabase.$myConn.Edit("tblpatdosing", "fldid=&1", $rFludRes["fldid"])
      res["fldcurval"] = xval
      res["xyz"] = False
      res.Update()
      ShowMedFluids()
    Endif
  Endif

End

Public Sub grdfluid_Select()

  If grdfluid.Selection.Count Then
    $rFludRes.MoveTo(grdfluid.Selection[0])
    btnivclose.Visible = True
    txtfluidname.Text = $rFludRes["flditem"]
    FillFluidGridView($rFludRes["fldid"])
    lblduration.Text = $rFludRes["flddirection"]
  Endif

End

Public Sub btnivstart_Click()

  If grdfluid.Selection.Count Then
    $rFludRes.MoveTo(grdfluid.Selection[0])

    If $rFludRes["fldcurval"] = "Continue" Then
      If GetFluidAdminStatusCode($rFludRes["fldid"]) = "icon:/small/next" Then
        If txtrate.Value Then
          modPharmSub.InsertNurDosing($encid, $rFludRes["fldid"], 0, txtrate.Value, "mL/Hour", Now())
          FillFluidGridView($rFludRes["fldid"])
          ShowMedFluids()
          txtrate.Value = 0
        Endif
      Endif
    Endif

  Endif

End

Private Sub FillFluidGridView(dosno As Long)

  $rRateRes = modDatabase.$syConn.Exec("select fldid,fldid,fldvalue,fldunit,fldid,fldfromtime,fldtotime,flddoseno from tblnurdosing where fldencounterval=&1 and flddoseno=&2 and fldfromtime IS NOT NULL ORDER BY fldid DESC", $encid, dosno)
  $aRateFields = New String[]
  modGridView.ReadSmallData(grdfluiddata, $rRateRes, $aRateFields)

  With grdfluiddata
    .Columns[0].Width = CStr(25 * modBasic.$AppWidthRatio) & "px"
    .Columns[1].Width = CStr(400 * modBasic.$AppWidthRatio) & "px"
    .Columns[2].Width = CStr(50 * modBasic.$AppWidthRatio) & "px"
    .Columns[3].Width = CStr(75 * modBasic.$AppWidthRatio) & "px"
    .Columns[4].Hidden = True
    .Columns[5].Width = CStr(150 * modBasic.$AppWidthRatio) & "px"
    .Columns[6].Width = CStr(150 * modBasic.$AppWidthRatio) & "px"
    .Columns[7].Hidden = True

    .Columns[1].Text = "Particulars"
    .Columns[2].Text = "Rate"
    .Columns[3].Text = "Unit"
    .Columns[5].Text = "Start"
    .Columns[6].Text = "Close"
  End With

End

Public Sub grdfluiddata_Data(Row As Integer, Column As Integer, Data As WebTableData)

  $rRateRes.MoveTo(Row)
  modGridView.GridViewDecoration(Data, Row)
  If Column = 0 Then
    Data.Html = modString.GetImageForHTMLGrid(modGeneralMain.GetSystemIcon(GetPictureDosing($rRateRes[$aRateFields[Column]])), "15px", "15px")
    Data.Text = ""
  Else If Column = 1 Then
    Data.Text = txtfluidname.Text
  Else If Column = 2 Then
    Data.Text = $rRateRes[$aRateFields[Column]]
  Else If Column = 5 Then
    Data.Text = modReportVar.GetDateTimeReport($rRateRes[$aRateFields[Column]], gb.GeneralDate)
  Else If Column = 6 Then
    Data.Text = modReportVar.GetDateTimeReport($rRateRes[$aRateFields[Column]], gb.GeneralDate)
  Else
    Data.Text = $rRateRes[$aRateFields[Column]]
  Endif

End

Public Sub btnivclose_Click()

  Dim res As Result

  If grdfluiddata.Selection.Count Then
    $rRateRes.MoveTo(grdfluiddata.Selection[0])
    If GetPictureDosing($rRateRes["fldid"]) = "icon:/small/stop" Then
      res = modDatabase.$myConn.Edit("tblnurdosing", "fldid=&1", $rRateRes["fldid"])
      res["fldtotime"] = Now()
      res["xyz"] = False
      res.Update
      FillFluidGridView($rRateRes["flddoseno"])
      ShowMedFluids()
    Endif
  Endif

End

Private Function GetPictureDosing(dosid As Long) As String

  Dim res As Result
  Dim xx As String

  res = modDatabase.$myConn.Exec("select flddoseno,fldfromtime,fldtotime from tblnurdosing where fldid=&1", dosid)
  If res.Available Then
    If res["fldfromtime"] And If Not res["fldtotime"] Then
      xx = "icon:/small/stop"
    Else If res["fldfromtime"] And If res["fldtotime"] Then
      xx = "icon:/small/lock"
    Endif
  Endif
  Return xx

End

Private Function GetFluidAdminStatusCode(dosno As Long) As String

  Dim res As Result
  Dim xx As String

  res = modDatabase.$syConn.Exec("select fldid,fldfromtime,fldtotime from tblnurdosing where fldencounterval=&1 and flddoseno=&2 ORDER BY fldid DESC", $encid, dosno)
  If res.Available Then
    If res["fldfromtime"] And If Not res["fldtotime"] Then
      xx = "icon:/small/stop"
    Else
      xx = "icon:/small/next"
    Endif
  Else
    xx = "icon:/small/next"
  Endif
  Return xx

End
