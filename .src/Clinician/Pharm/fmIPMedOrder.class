Public Sub _new(encid As String, sStatus As String, sPackage As String, sClass As String)

  Dim accLst As String[]
  Dim xbirthDate As Date

  $encid = encid
  $sTatus = sStatus
  $DiscPackage = sPackage
  If sClass Then
    WebContainer1.Class = sClass
  Else
    WebContainer1.Class = "height-tablet"
  Endif

  accLst = modNonMedical.GetHigherCostSchemes(modBasic.$BillDiscountCash, $DiscPackage)
  If accLst.Count = 0 Then
    accLst.Add($DiscPackage)
  Endif
  cmbdisctype.List = accLst
  cmbdisctype.Text = $DiscPackage
  If modNonMedical.GetAutoBillingLock($encid, $DiscPackage) = True Then
    cmbdisctype.Enabled = False
  Endif

  cmbstatus.List = $StateList
  cmbstatus.Add("%")
  cmbstatus.Text = "Continue"
  $ClinicianLst = modGeneral.GetClinicianCodeList()
  SetNarcoticsPrescriber()

  $ShowReview = modBasic.$MedErrorEnable
  If modPharmacy.DisableEncounterForReview($encid) = True Then
    $ShowReview = "None"
  Endif

  If modBasic.$ClinInjectionRoute = "Disable" Then
    cmbroute.List = modMedicine.ClinicalSubRoutes()
  Else
    cmbroute.List = modMedicine.ClinicalRoute()
  Endif
  cmbfreq.List = modMedicine.FrequencyCombo()

  $PatientNum = modPatient.GetPatientNoByEnc($encid)
  $xNHISCode = modPatient.GetPatientExtCOdebyEnc($encid)
  xbirthDate = modPatient.GetPatientBirthDay($encid)
  $PatAge = DateDiff(xbirthDate, Now(), gb.Year)
  $PatSex = modPatient.GetPatientSex($encid)
  $PatHeight = modClinic.GetPatientHeightinCm($encid)
  $PatWeight = modClinic.GetBodyWeight($encid)
  ShowBillingParam($DiscPackage)

  txtstart.Value = 0
  rbgeneric.Value = True
  rbroutine.Value = True
  ShowBasicParamStatus()
  LoadMedicineGrid()
  ShowAdmixtures()

End

Public Sub WebTabPanel1_Click()

  If WebTabPanel1.Index = 0 Then
    LoadMedicineGrid()
    ShowAdmixtures()
  Else If WebTabPanel1.Index = 1 Then
    ShowMedicines()
  Endif

End

Public Sub SetEntryOrder(sBool As Boolean)

  btnnewdose.Enabled = sBool
  btncpoe.Enabled = sBool
  btnrepeat.Enabled = sBool
  btngroup.Enabled = sBool
  btndispown.Enabled = sBool

End

Public Sub cmbdisctype_Click()

  If cmbdisctype.Text Then
    ShowBillingParam(cmbdisctype.Text)
  Endif

End

Private Sub ShowBillingParam(sDisctype As String)

  Dim hForm As CPackageParams

  ' $HiCappingVar = New Collection
  hForm = New CPackageParams($encid, sDisctype)
  $sBillMode = hForm.GetBillingMode()
  $LedgerAC = hForm.GetLedgerAC()
  $xBillType = hForm.GetBillType()
  $sClaimState = hForm.GetClaimState()

End

