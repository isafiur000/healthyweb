' Gambas module file

Public $claimFormat As String

''----------------------- Claim COde -----------------------
Public Function GetCurrentClaimCodeVIew(encid As String, xstatus As String) As String

  Dim xclaim As String

  xclaim = ShowOnlyClaimNew(encid, xstatus)

  Return xclaim

End

Public Function GetCurrentClaimCodePrint(encid As String) As String

  Dim xclaim As String
  Dim xstatus As String

  xstatus = GetClaimStatus(encid)
  xclaim = ShowOnlyClaimNew(encid, xstatus)

  Return xclaim

End

Public Function GetCurrentClaimCodeReport(encid As String) As String

  Dim xclaim As String
  Dim xstatus As String

  xstatus = GetClaimStatus(encid)
  If modBasic.$RegistCreateHIClaim = "Disable" Then
    xclaim = ShowOnlyClaimNew(encid, xstatus)
  Else
    xclaim = ShowOnlyClaimReport(encid, xstatus)
  Endif

  Return xclaim

End

Public Function GetClaimCidePatient(encid As String, claimType As String) As String

  Dim xclaim As String
  Dim xstatus As String

  xstatus = GetClaimStatus(encid)
  If claimType Then
    xclaim = ShowCreateClaimNew(encid, xstatus, claimType)
  Else
    xclaim = ShowCreateClaimNew(encid, xstatus)
  Endif

  Return xclaim

End

Private Sub GetClaimStatus(encid As String) As String

  Dim res As Result
  Dim xx As String

  res = modDatabase.$myConn.Exec("select fldadmission,fldadmitlocat from tblencounter where fldencounterval=&1", encid)
  If res.Available Then
    If res["fldadmission"] Then
      Select res["fldadmission"]
        Case "Admitted", "Discharged", "LAMA", "Death", "Refer", "Absconder"
          xx = "Patient Ward"
        Case Else
          If modGeneral.GetDepartCaption(res["fldadmitlocat"]) = "Emergency" Then
            xx = "Emergency"
          Else
            xx = "Consultation"
          Endif
      End Select
    Else
      xx = ""
    Endif
  Else
    xx = ""
  Endif
  Return xx

End

Public Sub SaveRemoteHiClaimCode(xClaim As String, xRemote As String)

  Dim res As Result

  res = modDatabase.$myConn.Edit("tblclaimcode", "fldclaimid=&1 and fldclaimcode IS NULL", xClaim)
  If res.Available Then
    res["fldclaimcode"] = xRemote
    res.Update
  Endif

End

Public Sub SaveClaimCappingLim(xClaim As String, xVar As String)

  Dim res As Result

  res = modDatabase.$myConn.Edit("tblclaimcode", "fldclaimid=&1", xClaim)
  If res.Available Then
    res["fldoutput"] = xVar
    res.Update
  Endif

End

Public Function GetClaimCappingLimit(encid As String, xClaim As String) As Collection

  Dim res As Result
  Dim res1 As Result
  Dim xval As String
  Dim xColl As Collection

  res = modDatabase.$myConn.Exec("select fldoutput from tblclaimcode where fldencounterval=&1 and fldclaimid=&2", encid, xClaim)
  If res.Available Then
    If res["fldoutput"] Then
      xval = res["fldoutput"]
    Else
      xval = ""
    Endif
  Else
    xval = ""
  Endif

  If Not xval Then
    res1 = modDatabase.$myConn.Exec("select fldoutput from tblclaimcode where fldencounterval=&1 and fldoutput IS NOT NULL ORDER BY fldtime DESC", encid)
    If res1.Available Then
      res1.MoveFirst
      If res1["fldoutput"] Then
        xval = res1["fldoutput"]
      Else
        xval = ""
      Endif
    Else
      xval = ""
    Endif
  Endif

  If xval Then
    xColl = JSON.Decode(xval)
  Else
    xColl = New Collection
  Endif

  Return xColl

End

Public Function GetRemoteClaimCode(xClaim As String) As String

  Dim res As Result
  Dim xx As String

  res = modDatabase.$myConn.Exec("select fldclaimcode from tblclaimcode where fldclaimid=&1", xClaim)
  If res.Available Then
    If res["fldclaimcode"] Then
      xx = res["fldclaimcode"]
    Else
      xx = ""
    Endif
  Else
    xx = ""
  Endif
  Return xx

End

Public Function GetNewClaimCode(encid As String, Optional xType As String) As String

  Dim res As Result
  Dim res2 As Result
  Dim aclaim As String
  Dim xclaim As String
  Dim xnhis As String

  xnhis = modPatient.GetPatientExtCOdebyEnc(encid)
  If Not xnhis Then
    xnhis = modNonMedical.GetPatientNHSIbyEncounter(encid)
  Endif
  If xnhis Then
    If modBasic.$RegistCreateHIClaim = "Disable" Then
      res2 = modDatabase.$myConn.Limit(2).Exec("select fldclaimid from tblclaimcode where fldencounterval IS NULL")
      If res2.Available Then
        res2.MoveFirst
        aclaim = res2["fldclaimid"]
        res = modDatabase.$myConn.Edit("tblclaimcode", "fldclaimid=&1 and fldencounterval IS NULL", aclaim)
        If res.Available Then
          res["fldencounterval"] = encid
          res["fldptcode"] = xnhis
          If xType Then
            res["fldclaimtype"] = xType
          Endif
          res["fldstatus"] = GetClaimStatus(encid)
          res["fldtime"] = Now()
          res["flduserid"] = modBasic.$lbluser
          res["xyz"] = False
          res.Update
          xclaim = aclaim
        Endif
      Else
        Message.Warning(("No Claim Code available. Please contact your administrator"), ("OK"))
      Endif

    Else
      modDatabase.$myConn.Begin
      aclaim = "HIB-" & modBillLock.CurrentHIClaim() & modBasic.$HospCode
      If aclaim Then
        res = modDatabase.$myConn.Create("tblclaimcode")
        res["fldclaimid"] = aclaim
        res["fldclaimcode"] = ""
        res["fldencounterval"] = encid
        res["fldptcode"] = xnhis
        If xType Then
          res["fldclaimtype"] = xType
        Endif
        res["fldstatus"] = GetClaimStatus(encid)
        res["fldtime"] = Now()
        res["flduserid"] = modBasic.$lbluser
        res["xyz"] = False
        res.Update
        xclaim = aclaim
        modDatabase.$myConn.Commit
      Else
        modDatabase.$myConn.Rollback
      Endif

    Endif
  Else
    Message.Warning("NHIS number is missing", ("OK"))
  Endif
  Return xclaim

End

Public Function CheckIMISStatus(encid As String) As String

  Dim hCElig As CimisAPIEligible
  Dim xnhis As String
  Dim res As Result
  Dim xmsg As String

  Dim xexpdate As Date
  Dim xcredamt As Float

  res = modDatabase.$myConn.Exec("select fldcashcredit,fldvalidity,fldadmission,fldadmitlocat from tblencounter where fldencounterval=&1", encid)
  If res.Available Then
    xnhis = modPatient.GetPatientExtCOdebyEnc(encid)
    If Not xnhis Then
      xnhis = modNonMedical.GetPatientNHSIbyEncounter(encid)
    Endif

    hCElig = New CimisAPIEligible(xnhis)
    xexpdate = hCElig.GetexpiryDaye()

    Select res["fldadmission"]
      Case "Recorded", "Registered"
        If modGeneral.GetDepartCaption(res["fldadmitlocat"]) = "Emergency" Then
          xcredamt = hCElig.GetAllowedMedAmt()
        Else
          xcredamt = hCElig.GetAllowedOPDAmt()
        Endif
      Case Else
        xcredamt = hCElig.GetAllowedMedAmt()
    End Select

    xmsg = "<b>Credit Limit :</b> " & CStr(xcredamt)
    xmsg = xmsg & "<br>" & "<b>Expiry :</b> " & Format(xexpdate, gb.MediumDate)
    If xcredamt <> res["fldcashcredit"] Then
      xmsg = xmsg & "<br>" & "<b>Credit LIMIT is different</b>"
    Endif
    If moddate.StartSqlDate(xexpdate) <> moddate.StartSqlDate(res["fldvalidity"]) Then
      xmsg = xmsg & "<br>" & "<b>Expiry DATE is different</b>"
    Endif
  Endif
  Return xmsg

End

Public Function CheckIMISValues(encid As String, DiscType As String) As Variant[]

  Dim hCElig As CimisAPIEligible
  Dim xnhis As String
  Dim res As Result
  Dim xmsg As Variant[]

  Dim xPatVar As Variant[]
  Dim aColl As Collection
  Dim policyLst As String[]
  Dim xpolicy As String
  Dim xexpdate As Date
  Dim xcredamt As Float
  Dim xpayval As Float

  res = modDatabase.$myConn.Exec("select fldcashcredit,fldvalidity,fldadmission,fldadmitlocat from tblencounter where fldencounterval=&1", encid)
  If res.Available Then
    xnhis = modPatient.GetPatientExtCOdebyEnc(encid)
    If Not xnhis Then
      xnhis = modNonMedical.GetPatientNHSIbyEncounter(encid)
    Endif

    hCElig = New CimisAPIEligible(xnhis)
    xPatVar = hCElig.GetPatientPolicyData()
    If xPatVar And If xPatVar.Count Then
      policyLst = modString.GetListFromVariant(xPatVar, "Policy Name", True)
      If policyLst.Count Then
        xpolicy = InputCombo("Select Policy", "Health Insurance", policyLst, "", True)
        If xpolicy Then

          For Each aColl In xPatVar
            If aColl["Policy Name"] = xpolicy Then
              xexpdate = aColl["Expiry Date"]
              If DiscType = modBasic.$HIPackage Then
                xpayval = aColl["Credit Value"]
              Else
                xpayval = 0
              Endif
              If aColl["Policy Name"] = "HIB-3500" Then
                Select res["fldadmission"]
                  Case "Recorded", "Registered"
                    If modGeneral.GetDepartCaption(res["fldadmitlocat"]) = "Emergency" Then
                      xcredamt = aColl["Medical Credit Limit"]
                    Else
                      xcredamt = aColl["OPD Credit Limit"] * (1 - xpayval)
                    Endif
                  Case Else
                    xcredamt = aColl["Medical Credit Limit"] * (1 - xpayval)
                End Select
              Else
                xcredamt = aColl["Medical Credit Limit"]
              Endif

              xmsg = [xcredamt, xexpdate, xpolicy]
              Break
            Endif
          Next

        Endif
      Endif
    Endif
  Endif
  Return xmsg

End

Public Function CheckFixedIMISValues(encid As String, sClaimCode As String, DiscType As String) As Variant[]

  Dim hCElig As CimisAPIEligible
  Dim res As Result
  Dim xmsg As Variant[]

  Dim xPatVar As Variant[]
  Dim aColl As Collection
  Dim xpolicy As String
  Dim xexpdate As Date
  Dim xcredamt As Float
  Dim xpayval As Float

  res = modDatabase.$myConn.Exec("select fldptcode,fldstatus,fldclaimtype from tblclaimcode where fldclaimid=&1 and fldencounterval=&2", sClaimCode, encid)
  If res.Available Then
    hCElig = New CimisAPIEligible(res["fldptcode"])
    xPatVar = hCElig.GetPatientPolicyData()
    If xPatVar And If xPatVar.Count Then
      If res["fldclaimtype"] Then
        xpolicy = res["fldclaimtype"]
      Else
        xpolicy = "HIB-3500"
      Endif
      If xpolicy Then

        For Each aColl In xPatVar
          If aColl["Policy Name"] = xpolicy Then
            xexpdate = aColl["Expiry Date"]
            If DiscType = modBasic.$HIPackage Then
              xpayval = aColl["Credit Value"]
            Else
              xpayval = 0
            Endif

            If aColl["Policy Name"] = "HIB-3500" Then
              Select res["fldstatus"]
                Case "Emergency"
                  xcredamt = aColl["Medical Credit Limit"]
                Case "Patient Ward"
                  xcredamt = aColl["Medical Credit Limit"] * (1 - xpayval)
                Case "Consultation"
                  xcredamt = aColl["OPD Credit Limit"] * (1 - xpayval)
              End Select
            Else
              xcredamt = aColl["Medical Credit Limit"]
            Endif

            xmsg = [xcredamt, xexpdate, xpolicy]
            Break
          Endif
        Next

      Endif
    Endif
  Endif
  Return xmsg

End

Public Sub UpdateCLaimToIPD(xnhis As String, aclaim As String)

  Dim res As Result

  res = modDatabase.$myConn.Edit("tblclaimcode", "fldclaimid=&1 and fldptcode=&2", aclaim, xnhis)
  res["fldstatus"] = "Patient Ward"
  res["xyz"] = False
  res.Update

End

