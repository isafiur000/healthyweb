' Gambas class file

Private $encid As String
Private $stockid As String

Private $dose As Float
Private $doseunit As String
Private $freq As String

Private cForm As CDoseLimits
Private $xVar As Variant[]
Private $codeid As String

Public Sub _new(encid As String, stockid As String)

  $encid = encid
  $stockid = stockid

  $codeid = modMedConstant.GetCodeFromStockID($stockid)
  $xVar = New Variant[]

End

Public Function GetOutputVariant() As Variant[]

  Return $xVar

End

Public Function GetOutputMessage() As String[]

  Dim messlst As String[]
  Dim sColl As Collection

  messlst = New String[]
  For Each sColl In $xVar
    messlst.Add("<u>[" & sColl["Category"] & "]</u>" & " <b>" & sColl["Drug"] & " : " & sColl["Condition"] & "</b>" & " :: " & sColl["Warning"])

    If modBasic.$MedLogRecommend = "Yes" Then
      modMedError.AddDrugProblemsPopUp($encid, sColl["Category"], sColl["Drug"], sColl["Condition"], sColl["Warning"], "")
    Endif
  Next

  Return messlst

End

''------------------------ Dosing Limits (require CheckDoseLimits() ) --------------------------------------------
Public Sub CheckDoseLimits(dose As Float, doseunit As String, freq As String)

  $dose = dose
  $doseunit = doseunit
  $freq = freq
  cForm = New CDoseLimits($encid, $stockid)

End

Public Sub MaximumUnitDose()

  Dim xColl As Collection
  Dim maxunitdose As Float

  'Maximum Unit Dose
  ' If $MaxUnitDose = "Yes" Then
  maxunitdose = cForm.GetMaxUnitDose()    'MaxUnitDoseDrug(encid, stockid)
  If maxunitdose > 0 Then
    If $dose > maxunitdose Then

      xColl = New Collection
      xColl.Add("Unit Dose", "Category")
      xColl.Add($codeid, "Drug")
      xColl.Add(CStr($dose) & Space(1) & $doseunit, "Condition")
      xColl.Add(GetMedicineReviewWarning($stockid, "MedicationReview/MaxUnitDose", maxunitdose), "Warning")
      $xVar.Add(xColl)

    Endif
  Endif
  ' Endif

End

Public Sub MaximumDailyDose()

  Dim xColl As Collection
  Dim maxdaydose As Float
  Dim freqval As Float

  'Maximum Dauly Dose
  ' If $MaxDailyDose = "Yes" Then
  freqval = modPharmLabel.ConvertFrequencyToNumber($freq)
  maxdaydose = cForm.GetMaxDailyDose()      'MaxDailyDoseDrug(encid, stockid)
  If maxdaydose > 0 Then
    If $dose * freqval > maxdaydose Then

      xColl = New Collection
      xColl.Add("Daily Dose", "Category")
      xColl.Add($codeid, "Drug")
      xColl.Add(CStr($dose * freqval) & Space(1) & $doseunit, "Condition")
      xColl.Add(GetMedicineReviewWarning($stockid, "MedicationReview/MaxDailyDose", maxdaydose), "Warning")
      $xVar.Add(xColl)

    Endif
  Endif
  ' Endif

End

Public Sub MinimumDailyDose()

  Dim xColl As Collection
  Dim mindaydose As Float
  Dim freqval As Float

  'Minimum Daily Dose
  ' If $MinDailyDose = "Yes" Then
  freqval = modPharmLabel.ConvertFrequencyToNumber($freq)
  mindaydose = cForm.GetMinDailyDose()       'MinDailyDoseDrug(encid, stockid)
  If mindaydose > 0 Then
    If $dose * freqval < mindaydose Then

      xColl = New Collection
      xColl.Add("Daily Dose", "Category")
      xColl.Add($codeid, "Drug")
      xColl.Add(CStr($dose * freqval) & Space(1) & $doseunit, "Condition")
      xColl.Add(GetMedicineReviewWarning($stockid, "MedicationReview/MinDailyDose", mindaydose), "Warning")
      $xVar.Add(xColl)

    Endif
  Endif
  ' Endif

End

Public Sub MaximumFrequency()

  Dim xColl As Collection
  Dim maxfreq As Float
  Dim freqval As Float

  'Maximum Frequency
  ' If $MaxFrequency = "Yes" Then
  freqval = modPharmLabel.ConvertFrequencyToNumber($freq)
  maxfreq = cForm.GetMaxFrequency()       'GetMaxFrequency(encid, stockid)
  If maxfreq > 0 Then
    If freqval > maxfreq Then

      xColl = New Collection
      xColl.Add("Frequency", "Category")
      xColl.Add($codeid, "Drug")
      xColl.Add(CStr(freqval) & " times", "Condition")
      xColl.Add(GetMedicineReviewWarning($stockid, "MedicationReview/MaxFrequency", maxfreq), "Warning")
      $xVar.Add(xColl)

    Endif
  Endif
  ' Endif

End

''------------------------ Non dosing -------------------------------------
Public Sub DoseBreaking(xDose As Float, sRoute As String)

  Dim xColl As Collection

  'Dose Breaking
  ' If $DoseBreak = "Yes" Then
  If modMedConstant.GetAllowTabBreak($stockid) = "No" Then
    If xDose > 0 And If modMedConstant.GetDrugInitialStrength($stockid) > xDose And If sRoute = "oral" Then

      xColl = New Collection
      xColl.Add("Dosage Form", "Category")
      xColl.Add($stockid, "Drug")
      xColl.Add(CStr(xDose), "Condition")
      xColl.Add(GetMedicineReviewWarning($stockid, "MedicationReview/DoseBreak"), "Warning")
      $xVar.Add(xColl)

    Endif
  Endif
  ' Endif

End

Public Sub PRNRestriction(sFreq As String)

  Dim xColl As Collection

  'PRN Restriction
  ' If $PRNRestriction = "Yes" Then
  If modMedConstant.GetAllowPRN($stockid) = "No" Then
    If sFreq = "PRN" Then

      xColl = New Collection
      xColl.Add("PRN Use", "Category")
      xColl.Add($codeid, "Drug")
      xColl.Add("PRN", "Condition")
      xColl.Add(GetMedicineReviewWarning($stockid, "MedicationReview/PRNRestriction"), "Warning")
      $xVar.Add(xColl)

    Endif
  Endif
  ' Endif

End

Public Sub PregnancyPrecaution(pregstat As String)

  Dim xColl As Collection
  Dim xWarn As String

  ''Pregnancy
  ' pregstat = modPatient.GetPregnancyStatus($encid)
  ' If $PregnancyPrecaution = "Yes" Then
  If pregstat And If pregstat <> "None" Then
    xWarn = GetMedicineReviewWarningMultiple($stockid, "MedicationReview/PregnancyPrecaution", pregstat)
    If xWarn Then

      xColl = New Collection
      xColl.Add("Pregnancy Status", "Category")
      xColl.Add($codeid, "Drug")
      xColl.Add(pregstat, "Condition")
      xColl.Add(xWarn, "Warning")
      $xVar.Add(xColl)

    Endif
  Endif
  ' Endif

End

