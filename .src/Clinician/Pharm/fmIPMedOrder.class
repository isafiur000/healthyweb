Private Sub SetNarcoticsPrescriber()

  Dim res As Result

  If modBasic.$MedNarcoPrescriber = "User" Then
    res = modDatabase.$myConn.Exec("select fldusername,fldusercode from tbluser where flduserid=&1 and (fldopconsult=&2 or fldipconsult=&2) and fldstatus=&3 and fldusercode like &4", modBasic.$lbluser, True, "Active", "%")
    If res.Available Then
      $NarcoDoctor = res["fldusername"]
      $NarcoRegd = res["fldusercode"]
    Endif
  Endif

End

Private Sub ShowBasicParamStatus()

  Dim xmsg As String

  If $ShowReview = "None" Then
  Else

    xmsg = ""
    If Not $PatHeight Then
      $PatHeight = modSysCons.GetPatientEmptyHeight($PatAge, $PatSex)
      If $PatHeight Then
        xmsg = "Patient's height not set. Using " & $PatHeight & " cm for now" & gb.NewLine
      Endif
    Endif
    If Not $PatWeight Then
      If $PatHeight Then
        $PatWeight = modSysCons.GetPatientEmptyWeight($PatHeight, $PatSex)
        If $PatWeight Then
          xmsg = xmsg & "Patient's weight not set. Using " & $PatWeight & " Kg for now"
        Endif
      Endif
    Endif

    If xmsg Then
      ' Me.Exec(Subst("Toastify({text: '&1', duration: &2}).showToast()", xmsg, modBasic.$BalloonDelay))
    Endif

  Endif

End

Public Sub btnshow_Click()

  LoadMedicineGrid()
  ShowAdmixtures()

End

Private Sub LoadMedicineGrid()

  Dim sFieldLst As String[]
  Dim sql As String

  sFieldLst = ["fldid", "fldroute", "CONCAT(flditem, '|', COALESCE(fldmixing, ''))", "CONCAT(flditem, '|', flddose)", "fldfreq", "flddays", "fldcurval", "fldqtyorder", "fldid", "flduserid", "fldstarttime", "fldid", "flddirection", "fldadminsite", "fldmixing", "flduserid", "flditem", "fldmixvolume", "fldmixrate", "flddose", "CONCAT(fldroute, '|', flditem, '|', flddose, '|', fldmixvolume, '|', fldmixrate)"]
  If cmbstatus.Text = "%" Then
    sql = "select " & sFieldLst.Join(",") & " from tblinpatdosing where fldencounterval=&1 and (fldmixing IS NULL or fldmixing NOT LIKE &2) ORDER BY fldstarttime DESC"
  Else
    sql = "select " & sFieldLst.Join(",") & " from tblinpatdosing where fldencounterval=&1 and (fldmixing IS NULL or fldmixing NOT LIKE &2) and fldcurval=&3 and fldsave=&4 ORDER BY fldstarttime DESC"
  Endif
  $rData = modDatabase.$myConn.Exec(sql, $encid, "ADMIXTURE:" & "%", cmbstatus.Text, False)
  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView1, $rData, $aMyFields)

  With GridView1
    .Columns[0].Hidden = True
    .Columns[1].Width = CStr(75 * modBasic.$AppWidthRatio) & "px"
    .Columns[2].Width = CStr(300 * modBasic.$AppWidthRatio) & "px"
    .Columns[3].Width = CStr(100 * modBasic.$AppWidthRatio) & "px"
    .Columns[4].Width = CStr(100 * modBasic.$AppWidthRatio) & "px"
    .Columns[5].Width = CStr(50 * modBasic.$AppWidthRatio) & "px"
    .Columns[6].Width = CStr(100 * modBasic.$AppWidthRatio) & "px"
    .Columns[7].Width = CStr(50 * modBasic.$AppWidthRatio) & "px"
    .Columns[8].Hidden = True
    .Columns[9].Width = CStr(125 * modBasic.$AppWidthRatio) & "px"
    .Columns[10].Width = CStr(150 * modBasic.$AppWidthRatio) & "px"
    .Columns[11].Width = CStr(50 * modBasic.$AppWidthRatio) & "px"
    .Columns[12].Width = CStr(150 * modBasic.$AppWidthRatio) & "px"
    .Columns[13].Width = CStr(150 * modBasic.$AppWidthRatio) & "px"
    .Columns[14].Width = CStr(250 * modBasic.$AppWidthRatio) & "px"
    .Columns[15].Hidden = True
    .Columns[16].Hidden = True
    .Columns[17].Width = CStr(75 * modBasic.$AppWidthRatio) & "px"
    .Columns[18].Width = CStr(75 * modBasic.$AppWidthRatio) & "px"
    .Columns[19].Hidden = True  ''Dose in number
    .Columns[20].Width = CStr(100 * modBasic.$AppWidthRatio) & "px"

    .Columns[1].Text = "Route"
    .Columns[2].Text = "Medicine"
    .Columns[3].Text = "Dose"
    .Columns[4].Text = "Freq"
    .Columns[5].Text = "Days"
    .Columns[6].Text = "Status"
    .Columns[7].Text = "QTY"
    .Columns[9].Text = "Doctor"
    .Columns[10].Text = "Start"
    .Columns[11].Text = "N"
    .Columns[12].Text = "Direction"
    .Columns[13].Text = "Admin"
    .Columns[14].Text = "Dilution"
    .Columns[17].Text = "Vol(mL)"
    .Columns[18].Text = "Rate"
    .Columns[20].Text = "Target"
  End With

End

Public Sub GridView1_Data(Row As Integer, Column As Integer, Data As WebTableData)

  $rData.MoveTo(Row)
  modGridView.GridViewDecoration(Data, Row)
  If Column = 2 Then
    Data.Html = GetInjectionName($rData[$aMyFields[Column]])
  Else If Column = 3 Then
    Data.Text = GetMedicineDose($rData[$aMyFields[Column]])
  Else If Column = 9 Then
    Data.Text = modGeneral.GetUserFullName($rData[$aMyFields[Column]])
  Else If Column = 10 Then
    Data.Text = modReportVar.GetDateTimeReport($rData[$aMyFields[Column]], gb.GeneralDate)
  Else If Column = 11 Then
    Data.Text = ""
  Else If Column = 20 Then
    Data.Text = GetDosingTarget($rData[$aMyFields[Column]])
  Else
    Data.Text = $rData[$aMyFields[Column]]
  Endif

End

Private Function GetMedicineDose(sItem As String) As String

  Dim asx As String[]
  Dim xx As String

  asx = Split(sItem, "|")
  If asx.Count = 2 Then
    xx = asx[1] & Space(1) & modMedConstant.GetMedicineDoseUnit(asx[0])
  Else
    xx = ""
  Endif

  Return xx

End

Private Function GetInjectionName(sItem As String) As String

  Dim asx As String[]
  Dim xx As String

  asx = Split(sItem, "|")
  If asx.Count = 2 Then
    If Trim(asx[1]) Then
      xx = asx[0] & " <small>[" & asx[1] & "]</small>"
    Else
      xx = asx[0]
    Endif
  Else
    xx = asx[0]
  Endif

  Return xx

End

Private Function GetDosingTarget(sValue As String) As String

  Dim asx As String[]
  Dim xunit As String
  Dim xval As Float
  Dim xx As String

  asx = Split(sValue, "|")
  If asx.Count = 5 Then
    Select asx[0]
      Case "CIV", "CIn(Epid)", "CIn(Block)"
        If asx[3] And If CFloat(asx[3]) Then
          xunit = modMedConstant.GetMedicineDoseUnit(asx[1])
          xval = (CFloat(asx[2]) * CFloat(asx[4])) / (CFloat(asx[3]) * 60)
          xx = CStr(Round(xval, -3)) & Space(1) & xunit & "/min"
        Else
          xx = ""
        Endif
      Case Else
        xx = ""
    End Select
  Else
    xx = ""
  Endif

  Return xx

End

Public Sub txtmeddose_Click()

  Dim xval As Float
  Dim res As Result

  If GridView1.Selection.Count Then
    $rData.MoveTo(GridView1.Selection[0])
    If modGeneral.AllowClinicalEdit($rData["flduserid"]) = True Then
      If $rData["flddose"] Then
        xval = InputValue($rData["flditem"], ("Alter Unit Dose"), $rData["flddose"])
      Else
        xval = InputValue($rData["flditem"], ("Alter Unit Dose"), 0)
      Endif
      If xval Then
        res = modDatabase.$myConn.Edit("tblinpatdosing", "fldid=&1 and fldencounterval=&2", $rData["fldid"], $encid)
        res["flddose"] = xval
        res["xyz"] = False
        res.Update
        LoadMedicineGrid()
      Endif
    Endif
  Endif

End

